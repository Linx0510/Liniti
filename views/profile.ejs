                        <path d="M106.995 156.687C106.285 156.871 105.339 157.517 104.807 158.116C104.275 158.807 102.619 166.921 100.253 180.289L96.5859 201.403L97.7688 202.647C98.7151 203.661 99.4248 203.892 101.495 203.892C105.812 203.892 105.694 204.169 109.834 180.474L113.501 159.36L112.318 158.116C111.017 156.733 108.829 156.134 106.995 156.687Z" fill="#CF2F2F" fill-opacity="0.5"/>
                        <path d="M43.5936 157.839C42.943 158.531 42.3516 159.407 42.3516 159.775C42.3516 160.19 43.9484 169.733 45.9001 181.027C49.9219 204.122 49.8627 203.892 54.1802 203.892C56.2502 203.892 56.9599 203.662 57.9062 202.647L59.089 201.403L55.4222 180.289C51.3413 156.825 51.4004 156.963 47.2604 156.733C45.2496 156.595 44.6581 156.779 43.5936 157.839Z" fill="#CF2F2F" fill-opacity="0.5"/>
                        <path d="M74.585 157.793L73.1064 158.9V180.612V202.325L74.585 203.431C76.4776 204.953 79.1982 204.953 81.0908 203.431L82.5693 202.325V180.612V158.9L81.0908 157.793C80.2036 157.056 78.9616 156.641 77.8379 156.641C76.7142 156.641 75.4722 157.056 74.585 157.793Z" fill="#CF2F2F" fill-opacity="0.5"/>
                        <path d="M44.3035 46.6951C43.5938 47.11 42.5292 48.4929 41.9969 49.8759C41.1689 51.9964 41.1098 52.5035 41.8195 53.656C42.8249 55.2695 45.2498 56.0531 47.5563 55.4077C49.3898 54.9468 51.7555 51.6737 51.8146 49.5532C51.8146 46.7873 47.3198 45.0816 44.3035 46.6951Z" fill="#CF2F2F" fill-opacity="0.5"/>
                        <path d="M22.2429 49.6915C20.3503 51.1667 20.4686 52.9645 22.6569 56.3759C23.4849 57.6205 24.6678 59.1418 25.3775 59.695C28.0389 61.9999 32.8887 60.2943 32.8887 57.1595C32.8887 55.5 30.523 51.4433 28.5712 49.7837C27.0335 48.493 23.8989 48.4008 22.2429 49.6915Z" fill="#CF2F2F" fill-opacity="0.5"/>
                        <path d="M6.86548 60.4328C3.49432 61.7697 3.84918 65.4576 7.57519 66.8867C11.4195 68.3618 13.6669 68.4079 15.3821 67.0711C18.3984 64.72 17.0381 61.8158 12.3658 60.5711C9.05377 59.6953 8.75805 59.6953 6.86548 60.4328Z" fill="#CF2F2F" fill-opacity="0.5"/>
                        <path d="M41.6425 67.3933C36.0239 69.6983 18.1627 78.4109 16.8615 79.5173C15.9744 80.2088 14.9689 81.5918 14.5549 82.5598C13.2538 85.7868 14.1409 87.6307 20.6467 95.5597L26.6793 102.936L32.1796 103.074C35.1367 103.12 37.6207 103.074 37.6207 102.889C37.6207 102.705 34.427 98.6944 30.5236 93.9001C26.6201 89.152 23.4264 85.0492 23.4264 84.8187C23.4264 84.4038 43.4759 74.8152 43.7716 75.1379C43.8307 75.184 46.7879 78.7797 50.2773 83.113C59.2079 94.0845 60.3317 94.8682 66.4234 94.8682C69.7946 94.8682 70.2677 94.7299 80.7952 89.7513C90.9678 85.0031 91.7366 84.7265 92.5055 85.5102C92.9195 85.9711 96.4089 90.12 100.194 94.7299L107.055 103.166H112.555C117.76 103.166 118.055 103.12 117.523 102.336C115.808 99.8469 98.3015 78.7797 97.0595 77.7656C96.2906 77.1202 94.8712 76.3365 93.9841 76.0599C90.1398 74.8613 48.0891 66.7479 45.7825 66.7479C44.363 66.7479 42.5296 67.0706 41.6425 67.3933ZM68.9074 78.5031C74.94 79.6556 80.0854 80.762 80.3812 80.9003C81.0909 81.223 66.66 87.9534 65.7728 87.6768C65.1814 87.4924 56.6056 77.489 56.0142 76.2904C55.8959 76.0599 56.3099 75.9677 56.9014 76.1521C57.5519 76.2904 62.934 77.3507 68.9074 78.5031Z" fill="#CF2F2F" fill-opacity="0.5"/>
                    </svg>

                    <h3>Работа удалена</h3>
                    <p>Ждем ваших новых работ!</p>
                </div>
            </div>
        </div>
    </div>

    <div id="reportModal" class="report-modal" aria-hidden="true">
        <div class="report-modal-overlay" data-close-report-modal></div>
        <div class="report-modal-content" role="dialog" aria-modal="true" aria-labelledby="reportModalTitle">
            <button class="report-modal-close" type="button" data-close-report-modal aria-label="Закрыть">&times;</button>
            <h2 id="reportModalTitle">Пожаловаться на работу</h2>

            <form action="/works/report" method="POST" class="report-form" id="reportForm">
                <div style="display: flex; flex-direction: column;" id="reportFormFields">
                    <div class="report-form-group">
                        <input type="hidden" name="reason" id="reportReasonValue" required>
                        <input type="hidden" name="csrf_token" value="<%= csrfToken %>">
                        <div class="report-reasons-list" role="group" aria-label="Причина жалобы">
                            <label class="report-reason-item">
                                <input type="checkbox" class="report-reason-checkbox" value="spam">
                                <span class="report-reason-text">
                                    <span class="report-reason-title">Спам</span>
                                    <span class="report-reason-description">Вводящие в заблуждение или повторяющиеся публикации.</span>
                                </span>
                            </label>
                            <label class="report-reason-item">
                                <input type="checkbox" class="report-reason-checkbox" value="sexual_content">
                                <span class="report-reason-text">
                                    <span class="report-reason-title">Сексуальный контент</span>
                                    <span class="report-reason-description">Изображения обнаженного тела, порнография или содержимое сексуального характера.</span>
                                </span>
                            </label>
                            <label class="report-reason-item">
                                <input type="checkbox" class="report-reason-checkbox" value="self_harm">
                                <span class="report-reason-text">
                                    <span class="report-reason-title">Членовредительство</span>
                                    <span class="report-reason-description">Расстройства пищевого поведения, нанесение травм себе, суицид.</span>
                                </span>
                            </label>
                            <label class="report-reason-item">
                                <input type="checkbox" class="report-reason-checkbox" value="misinformation">
                                <span class="report-reason-text">
                                    <span class="report-reason-title">Ложная информация</span>
                                    <span class="report-reason-description">Ложная информация о здоровье, климате, голосованиях или теории заговора.</span>
                                </span>
                            </label>
                            <label class="report-reason-item">
                                <input type="checkbox" class="report-reason-checkbox" value="hate_or_abuse">
                                <span class="report-reason-text">
                                    <span class="report-reason-title">Агрессивные действия</span>
                                    <span class="report-reason-description">Предрассудки, стереотипы, оскорбления, пропаганда превосходства.</span>
                                </span>
                            </label>
                            <label class="report-reason-item">
                                <input type="checkbox" class="report-reason-checkbox" value="dangerous_goods">
                                <span class="report-reason-text">
                                    <span class="report-reason-title">Опасные товары</span>
                                    <span class="report-reason-description">Наркотики, оружие, регулируемые товары.</span>
                                </span>
                            </label>
                            <label class="report-reason-item">
                                <input type="checkbox" class="report-reason-checkbox" value="harassment">
                                <span class="report-reason-text">
                                    <span class="report-reason-title">Преследование или критика</span>
                                    <span class="report-reason-description">Оскорбления, угрозы, кибербуллинг, публикации без разрешения.</span>
                                </span>
                            </label>
                            <label class="report-reason-item">
                                <input type="checkbox" class="report-reason-checkbox" value="violence">
                                <span class="report-reason-text">
                                    <span class="report-reason-title">Сцены насилия</span>
                                    <span class="report-reason-description">Графическое изображение или пропаганда насилия, терроризм, экстремизм.</span>
                                </span>
                            </label>
                            <label class="report-reason-item">
                                <input type="checkbox" class="report-reason-checkbox" value="privacy">
                                <span class="report-reason-text">
                                    <span class="report-reason-title">Нарушение конфиденциальности</span>
                                    <span class="report-reason-description">Личные фотографии или персональная информация.</span>
                                </span>
                            </label>
                            <label class="report-reason-item">
                                <input type="checkbox" class="report-reason-checkbox" value="intellectual_property">
                                <span class="report-reason-text">
                                    <span class="report-reason-title">Интеллектуальная собственность</span>
                                    <span class="report-reason-description">Нарушение авторских прав или прав на товарный знак.</span>
                                </span>
                            </label>
                        </div>
                        <p class="report-validation-error" id="reportValidationError" role="alert" style="display:none;">Выберите причину жалобы.</p>
                    </div>
                    <button style="margin-top: 20px;" type="submit" class="report-submit-btn">Отправить жалобу</button>
                </div>
            </form>

            <div class="report-success-state" id="reportSuccessState">
                <div class="success-content" role="status">
                    <svg class="success-icon" width="60" height="60" viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="30" cy="30" r="28" stroke="#8CBA0B" stroke-width="2" fill="white"/>
                        <path d="M18 30L26 38L42 22" stroke="#8CBA0B" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <h3>Сообщение отправлено!</h3>
                    <p>Спасибо за обращение. Мы обработаем вашу жалобу и отправим уведомление о результате.</p>
                </div>
            </div>
        </div>
    </div>
    
    <script>
        // Подписка/отписка
        document.querySelectorAll('.subscribe-btn').forEach(btn => {
            btn.addEventListener('click', async () => {
                const userId = btn.dataset.userId;
                const isSubscribed = btn.dataset.subscribed === 'true';

                try {
                    btn.disabled = true;
                    const response = await fetch('/api/subscribe', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-CSRF-Token': '<%= csrfToken %>'
                        },
                        body: JSON.stringify({ userId, action: isSubscribed ? 'unsubscribe' : 'subscribe' })
                    });

                    if (!response.ok) {
                        throw new Error('Ошибка изменения подписки');
                    }

                    const nextSubscribedState = !isSubscribed;
                    btn.dataset.subscribed = nextSubscribedState ? 'true' : 'false';
                    btn.textContent = nextSubscribedState ? 'Отписаться' : 'Подписаться';

                    const followersCounter = document.querySelector('.profile-stats .stat:nth-child(2) .stat-value');
                    if (followersCounter) {
                        const currentCount = Number(followersCounter.textContent) || 0;
                        followersCounter.textContent = Math.max(currentCount + (nextSubscribedState ? 1 : -1), 0);
                    }
                } catch (error) {
                    console.error(error);
                } finally {
                    btn.disabled = false;
                }
            });
        });

        const profileToast = document.getElementById('profileToast');
        if (profileToast) {
            window.setTimeout(() => {
                profileToast.classList.add('profile-toast--hidden');
            }, 2600);

            window.setTimeout(() => {
                profileToast.remove();
            }, 3200);

            if (window.history.replaceState) {
                const currentUrl = new URL(window.location.href);
                currentUrl.searchParams.delete('profile_updated');
                window.history.replaceState({}, document.title, currentUrl.pathname + currentUrl.search + currentUrl.hash);
            }
        }

        document.querySelectorAll('[data-gallery]').forEach((gallery) => {
            const track = gallery.querySelector('[data-gallery-track]');
            if (!track) return;
            const slides = Array.from(track.children);
            const prevBtn = gallery.querySelector('[data-gallery-prev]');
            const nextBtn = gallery.querySelector('[data-gallery-next]');

            let currentIndex = 0;

            const dotsContainer = document.createElement('div');
            dotsContainer.className = 'gallery-dots';

            const dots = slides.map((_, index) => {
                const dot = document.createElement('button');
                dot.type = 'button';
                dot.className = 'dot';
                dot.setAttribute('aria-label', `Перейти к изображению ${index + 1}`);
                dot.addEventListener('click', () => {
                    currentIndex = index;
                    updateGallery();
                });
                dotsContainer.appendChild(dot);
                return dot;
            });

            gallery.appendChild(dotsContainer);

            function updateGallery() {
                track.style.transform = `translateX(-${currentIndex * 100}%)`;
                dots.forEach((dot, index) => {
                    dot.classList.toggle('active', index === currentIndex);
                });
            }

            if (prevBtn) {
                prevBtn.addEventListener('click', () => {
                    currentIndex = (currentIndex - 1 + slides.length) % slides.length;
                    updateGallery();
                });
            }

            if (nextBtn) {
                nextBtn.addEventListener('click', () => {
                    currentIndex = (currentIndex + 1) % slides.length;
                    updateGallery();
                });
            }

            updateGallery();
        });

        const workViewerModal = document.getElementById('workViewerModal');
        const workViewerTitle = document.getElementById('workViewerTitle');
        const workViewerTrack = document.getElementById('workViewerTrack');
        const workViewerDescription = document.getElementById('workViewerDescription');
        const workViewerStats = document.getElementById('workViewerStats');
        const workViewerDots = document.getElementById('workViewerDots');
        const viewerPrevBtn = document.querySelector('[data-viewer-prev]');
        const viewerNextBtn = document.querySelector('[data-viewer-next]');
        const deleteWorkModal = document.getElementById('deleteWorkModal');
        const deleteWorkForm = document.getElementById('deleteWorkForm');
        const deleteWorkValidationError = document.getElementById('deleteWorkValidationError');
        const deleteWorkSuccessState = document.getElementById('deleteWorkSuccessState');
        const reportModal = document.getElementById('reportModal');
        const reportForm = document.getElementById('reportForm');
        const reportFormFields = document.getElementById('reportFormFields');
        const reportSuccessState = document.getElementById('reportSuccessState');
        const reportReasonValue = document.getElementById('reportReasonValue');
        const reportReasonCheckboxes = document.querySelectorAll('.report-reason-checkbox');
        const reportValidationError = document.getElementById('reportValidationError');
        const complainButtons = document.querySelectorAll('.btn-complain');
        let viewerImages = [];
        let viewerIndex = 0;
        let pendingDelete = null;

        const updateViewer = () => {
            workViewerTrack.style.transform = `translateX(-${viewerIndex * 100}%)`;
            Array.from(workViewerDots.children).forEach((dot, index) => {
                dot.classList.toggle('active', index === viewerIndex);
            });
        };

        const openWorkViewer = (card) => {
            if (!card) return;
            const title = card.querySelector('h3')?.textContent?.trim() || 'Работа';
            const description = card.querySelector('.work-description')?.textContent?.trim() || 'Описание отсутствует';
            const statItems = Array.from(card.querySelectorAll('.work-stats span')).map((node) => node.textContent.trim());
            const images = Array.from(card.querySelectorAll('.work-image img')).map((img) => ({
                src: img.src,
                alt: img.alt || title
            }));

            viewerImages = images.length ? images : [{ src: '/img/work_img.svg', alt: title }];
            viewerIndex = 0;

            workViewerTitle.textContent = title;
            workViewerDescription.textContent = description;
            workViewerStats.innerHTML = statItems.map((stat) => `<span>${stat}</span>`).join('');
            workViewerTrack.innerHTML = viewerImages.map((image) => `
                <div class="work-viewer-image">
                    <img src="${image.src}" alt="${image.alt}">
                </div>
            `).join('');
            workViewerDots.innerHTML = viewerImages.map((_image, index) => `
                <button type="button" class="dot ${index === 0 ? 'active' : ''}" aria-label="Перейти к изображению ${index + 1}"></button>
            `).join('');

            Array.from(workViewerDots.children).forEach((dot, index) => {
                dot.addEventListener('click', () => {
                    viewerIndex = index;
                    updateViewer();
                });
            });

            updateViewer();
            workViewerModal.classList.add('is-open');
            workViewerModal.setAttribute('aria-hidden', 'false');
            document.body.classList.add('modal-open');
        };

        const closeWorkViewer = () => {
            workViewerModal.classList.remove('is-open');
            workViewerModal.setAttribute('aria-hidden', 'true');
            document.body.classList.remove('modal-open');
        };

        const openDeleteWorkModal = (workId, card, btn) => {
            pendingDelete = { workId, card, btn };
            deleteWorkValidationError.style.display = 'none';
            deleteWorkValidationError.textContent = '';
            if (deleteWorkForm) deleteWorkForm.style.display = 'flex';
            if (deleteWorkSuccessState) deleteWorkSuccessState.classList.remove('is-visible');
            deleteWorkModal.classList.add('is-open');
            deleteWorkModal.setAttribute('aria-hidden', 'false');
            document.body.classList.add('modal-open');
        };

        const closeDeleteWorkModal = () => {
            deleteWorkModal.classList.remove('is-open');
            deleteWorkModal.setAttribute('aria-hidden', 'true');
            document.body.classList.remove('modal-open');
            if (pendingDelete?.btn) {
                pendingDelete.btn.disabled = false;
            }
            pendingDelete = null;
        };

        const getSelectedReportReasons = () => Array.from(reportReasonCheckboxes)
            .filter((checkbox) => checkbox.checked)
            .map((checkbox) => checkbox.value);

        const hideReportValidationError = () => {
            if (reportValidationError) reportValidationError.style.display = 'none';
        };

        const showReportValidationError = () => {
            if (reportValidationError) reportValidationError.style.display = 'block';
        };

        const syncReportReasonSelection = (activeCheckbox) => {
            if (!reportReasonCheckboxes.length) return;

            reportReasonCheckboxes.forEach((checkbox) => {
                if (checkbox !== activeCheckbox) checkbox.checked = false;
            });

            const selectedReasons = getSelectedReportReasons();
            if (reportReasonValue) {
                reportReasonValue.value = selectedReasons[0] || '';
            }
            if (selectedReasons.length > 0) {
                hideReportValidationError();
            }
        };

        const openReportModal = (workId) => {
            if (!reportModal) return;
            if (reportForm) {
                reportForm.action = workId ? `/works/${workId}/report` : '/works/report';
            }
            syncReportReasonSelection(null);
            if (reportFormFields) reportFormFields.style.display = 'flex';
            if (reportSuccessState) reportSuccessState.classList.remove('is-visible');

            reportModal.classList.add('is-open');
            reportModal.setAttribute('aria-hidden', 'false');
            document.body.classList.add('modal-open');
        };

        const closeReportModal = () => {
            if (!reportModal) return;
            reportModal.classList.remove('is-open');
            reportModal.setAttribute('aria-hidden', 'true');

            if (reportForm) reportForm.reset();
            syncReportReasonSelection(null);
            if (reportFormFields) reportFormFields.style.display = 'flex';
            if (reportSuccessState) reportSuccessState.classList.remove('is-visible');

            document.body.classList.remove('modal-open');
        };

        document.querySelectorAll('[data-open-work]').forEach((btn) => {
            btn.addEventListener('click', () => {
                openWorkViewer(btn.closest('.work-card'));
            });
        });

        document.querySelectorAll('[data-delete-work]').forEach((btn) => {
            btn.addEventListener('click', async (event) => {
                event.stopPropagation();
                const card = btn.closest('.work-card');
                const workId = card?.dataset?.workId;
                if (!workId) return;
                btn.disabled = true;
                openDeleteWorkModal(workId, card, btn);
            });
        });

        complainButtons.forEach((button) => {
            button.addEventListener('click', () => {
                openReportModal(button.dataset.workId || '');
            });
        });

        reportReasonCheckboxes.forEach((checkbox) => {
            checkbox.addEventListener('change', () => {
                syncReportReasonSelection(checkbox);
            });
        });

        reportForm?.addEventListener('submit', async (event) => {
            event.preventDefault();

            const selectedReasons = getSelectedReportReasons();
            if (selectedReasons.length === 0) {
                showReportValidationError();
                return;
            }

            if (reportReasonValue) {
                reportReasonValue.value = selectedReasons[0];
            }

            if (!reportForm.checkValidity()) {
                reportForm.reportValidity();
                return;
            }

            const submitButton = reportForm.querySelector('button[type="submit"]');

            try {
                if (submitButton) submitButton.disabled = true;

                const response = await fetch(reportForm.action, {
                    method: 'POST',
                    body: new URLSearchParams(new FormData(reportForm)),
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8'
                    }
                });

                if (!response.ok) {
                    throw new Error('Ошибка при отправке жалобы');
                }

                if (reportFormFields) reportFormFields.style.display = 'none';
                if (reportSuccessState) reportSuccessState.classList.add('is-visible');
                reportForm.reset();
                syncReportReasonSelection(null);
            } catch (_error) {
                alert('Не удалось отправить жалобу. Попробуйте еще раз.');
            } finally {
                if (submitButton) submitButton.disabled = false;
            }
        });

        deleteWorkForm?.addEventListener('submit', async (event) => {
            event.preventDefault();
            if (!pendingDelete?.workId || !pendingDelete?.card) return;

            const { workId, card, btn } = pendingDelete;

            try {
                const response = await fetch(`/works/${workId}/delete`, {
                    method: 'POST',
                    headers: {
                        'X-CSRF-Token': '<%= csrfToken %>'
                    }
                });
                const data = await response.json();

                if (!response.ok || !data.success) {
                    throw new Error(data.error || 'Не удалось удалить работу');
                }

                card.remove();
                const worksCounter = document.querySelector('.profile-stats .stat:last-child .stat-value');
                if (worksCounter) {
                    const currentCount = Number(worksCounter.textContent) || 0;
                    worksCounter.textContent = Math.max(currentCount - 1, 0);
                }
                if (deleteWorkForm) deleteWorkForm.style.display = 'none';
                if (deleteWorkSuccessState) deleteWorkSuccessState.classList.add('is-visible');
                setTimeout(() => {
                    closeDeleteWorkModal();
                }, 1500);
            } catch (error) {
                deleteWorkValidationError.textContent = error.message || 'Не удалось удалить работу';
                deleteWorkValidationError.style.display = 'block';
                if (btn) {
                    btn.disabled = false;
                }
            }
        });

        document.querySelectorAll('[data-close-delete-modal]').forEach((node) => {
            node.addEventListener('click', closeDeleteWorkModal);
        });
        document.querySelectorAll('[data-close-report-modal]').forEach((node) => {
            node.addEventListener('click', closeReportModal);
        });

        viewerPrevBtn?.addEventListener('click', () => {
            if (!viewerImages.length) return;
            viewerIndex = (viewerIndex - 1 + viewerImages.length) % viewerImages.length;
            updateViewer();
        });

        viewerNextBtn?.addEventListener('click', () => {
            if (!viewerImages.length) return;
            viewerIndex = (viewerIndex + 1) % viewerImages.length;
            updateViewer();
        });

        document.querySelectorAll('[data-close-work-viewer]').forEach((node) => {
            node.addEventListener('click', closeWorkViewer);
        });

        window.addEventListener('keydown', (event) => {
            if (event.key === 'Escape') {
                if (workViewerModal.classList.contains('is-open')) closeWorkViewer();
                if (deleteWorkModal.classList.contains('is-open')) closeDeleteWorkModal();
                if (reportModal?.classList.contains('is-open')) closeReportModal();
            }

            if (workViewerModal.classList.contains('is-open')) {
                if (event.key === 'ArrowLeft' && viewerImages.length) {
                    viewerIndex = (viewerIndex - 1 + viewerImages.length) % viewerImages.length;
                    updateViewer();
                }
                if (event.key === 'ArrowRight' && viewerImages.length) {
                    viewerIndex = (viewerIndex + 1) % viewerImages.length;
                    updateViewer();
                }
            }
        });

        document.querySelectorAll('.post-like-btn').forEach((button) => {
            button.addEventListener('click', async () => {
                const workId = button.dataset.workId;
                if (!workId) return;

                try {
                    const response = await fetch(`/api/works/${workId}/like`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        }
                    });

                    if (!response.ok) {
                        throw new Error('Like request failed');
                    }

                    const payload = await response.json();
                    const counter = button.querySelector('.post-like-count');
                    if (counter) {
                        counter.textContent = payload.likes;
                    }

                    button.classList.toggle('is-liked', Boolean(payload.liked));
                    button.dataset.liked = payload.liked ? 'true' : 'false';
                } catch (error) {
                    console.error('Не удалось поставить лайк:', error);
                }
            });
        });
    </script>
</body>
</html>
