<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= profileUser.first_name %> <%= profileUser.last_name %> | LineStok</title>
    <link rel="stylesheet" href="/css/profile.css">
    <link rel="stylesheet" href="/css/header.css">
</head>
<body>
    <main>
        <%- include('partials/header-actions') %>
        <% if (profileUpdated) { %>
            <div class="profile-toast" id="profileToast" role="status" aria-live="polite">
                Профиль успешно обновлён
            </div>
        <% } %>
        
        <div class="profile-container">
            <div class="contentprof">
                <% if (profileUser.bio) { %>
                    <div class="profile-bio">
                        <h3>О себе</h3>
                        <p><%= profileUser.bio %></p>
                    </div>
                <% } %>
            
                <div class="profile-works">
                    <h2>Работы пользователя</h2>
                    <div class="works-grid">
                        <% works.forEach(work => { %>
                            <div class="work-card" data-work-id="<%= work.id %>">
                                <% if (isOwnProfile) { %>
                                    <button
                                        class="delete-work-btn"
                                        type="button"
                                        data-delete-work
                                        aria-label="Удалить работу"
                                        title="Удалить работу">
                                        <svg width="24" height="24" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <path d="M18.5 4.00003H13.5C13.4342 3.99928 13.3688 4.0117 13.3078 4.03656C13.2468 4.06142 13.1914 4.09822 13.1448 4.1448C13.0982 4.19138 13.0614 4.2468 13.0366 4.3078C13.0117 4.36881 12.9993 4.43416 13 4.50003V6.00003H19V4.50003C19.0008 4.43416 18.9884 4.36881 18.9635 4.3078C18.9386 4.2468 18.9018 4.19138 18.8553 4.1448C18.8087 4.09822 18.7533 4.06142 18.6923 4.03656C18.6313 4.0117 18.5659 3.99928 18.5 4.00003Z" stroke="#393939" stroke-width="0.0625"/>
                                            <path d="M27 6H21V4.5C21 3.83696 20.7366 3.20107 20.2678 2.73223C19.7989 2.26339 19.163 2 18.5 2H13.5C12.837 2 12.2011 2.26339 11.7322 2.73223C11.2634 3.20107 11 3.83696 11 4.5V6H5C4.73478 6 4.48043 6.10536 4.29289 6.29289C4.10536 6.48043 4 6.73478 4 7C4 7.26522 4.10536 7.51957 4.29289 7.70711C4.48043 7.89464 4.73478 8 5 8H6.0625L7.25 27.0575C7.33875 28.7356 8.625 30 10.25 30H21.75C23.3831 30 24.6437 28.7638 24.75 27.0625L25.9375 8H27C27.2652 8 27.5196 7.89464 27.7071 7.70711C27.8946 7.51957 28 7.26522 28 7C28 6.73478 27.8946 6.48043 27.7071 6.29289C27.5196 6.10536 27.2652 6 27 6ZM12.0356 26H12C11.7408 26.0002 11.4917 25.8997 11.3052 25.7198C11.1187 25.5399 11.0092 25.2946 11 25.0356L10.5 11.0356C10.4906 10.7704 10.5868 10.5123 10.7677 10.3181C10.9486 10.1239 11.1992 10.0094 11.4644 10C11.7296 9.99055 11.9877 10.0868 12.1819 10.2677C12.3761 10.4486 12.4906 10.6992 12.5 10.9644L13 24.9644C13.0048 25.0957 12.9836 25.2267 12.9377 25.3499C12.8918 25.473 12.8221 25.5859 12.7325 25.6821C12.6429 25.7783 12.5353 25.8559 12.4157 25.9104C12.2961 25.965 12.167 25.9954 12.0356 26ZM17 25C17 25.2652 16.8946 25.5196 16.7071 25.7071C16.5196 25.8946 16.2652 26 16 26C15.7348 26 15.4804 25.8946 15.2929 25.7071C15.1054 25.5196 15 25.2652 15 25V11C15 10.7348 15.1054 10.4804 15.2929 10.2929C15.4804 10.1054 15.7348 10 16 10C16.2652 10 16.5196 10.1054 16.7071 10.2929C16.8946 10.4804 17 10.7348 17 11V25ZM19 6H13V4.5C12.9992 4.43413 13.0117 4.36877 13.0365 4.30777C13.0614 4.24677 13.0982 4.19135 13.1448 4.14477C13.1913 4.09819 13.2468 4.06139 13.3078 4.03652C13.3688 4.01166 13.4341 3.99925 13.5 4H18.5C18.5659 3.99925 18.6312 4.01166 18.6922 4.03652C18.7532 4.06139 18.8087 4.09819 18.8552 4.14477C18.9018 4.19135 18.9386 4.24677 18.9635 4.30777C18.9883 4.36877 19.0008 4.43413 19 4.5V6ZM21 25.0356C20.9908 25.2946 20.8813 25.5399 20.6948 25.7198C20.5083 25.8997 20.2592 26.0002 20 26H19.9638C19.8325 25.9953 19.7034 25.9648 19.5839 25.9102C19.4644 25.8557 19.3568 25.7781 19.2673 25.6819C19.1778 25.5857 19.1081 25.4728 19.0623 25.3497C19.0164 25.2266 18.9952 25.0957 19 24.9644L19.5 10.9644C19.5047 10.8331 19.5352 10.7039 19.5898 10.5844C19.6443 10.4649 19.7219 10.3573 19.8181 10.2677C19.9143 10.1782 20.0271 10.1084 20.1502 10.0625C20.2733 10.0166 20.4043 9.99532 20.5356 10C20.6669 10.0047 20.7961 10.0352 20.9156 10.0898C21.0351 10.1443 21.1427 10.2219 21.2323 10.3181C21.3218 10.4143 21.3916 10.5271 21.4375 10.6502C21.4834 10.7733 21.5047 10.9043 21.5 11.0356L21 25.0356Z" fill="#393939" stroke="#393939" stroke-width="0.0625"/>
                                        </svg>

                                    </button>
                                <% } else { %>
                                    <button class="btn-complain" title="Пожаловаться" data-work-id="<%= work.id %>">
                                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <path class="svg-hover" d="M12 22C14.7614 22 17.2614 20.8807 19.0711 19.0711C20.8807 17.2614 22 14.7614 22 12C22 9.2386 20.8807 6.7386 19.0711 4.92893C17.2614 3.11929 14.7614 2 12 2C9.2386 2 6.7386 3.11929 4.92893 4.92893C3.11929 6.7386 2 9.2386 2 12C2 14.7614 3.11929 17.2614 4.92893 19.0711C6.7386 20.8807 9.2386 22 12 22Z" fill="#292929"/>
                                            <path fill-rule="evenodd" clip-rule="evenodd" d="M12 18.5C12.6904 18.5 13.25 17.9404 13.25 17.25C13.25 16.5597 12.6904 16 12 16C11.3097 16 10.75 16.5597 10.75 17.25C10.75 17.9404 11.3097 18.5 12 18.5Z" fill="white"/>
                                            <path d="M12 6V14" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                        </svg>
                                    </button>
                                <% } %>
                                <% const profileImages = (work.images && work.images.length ? work.images : ['/img/work_img.svg']); %>
                                <div class="work-gallery" data-gallery>
                                    <button class="gallery-arrow gallery-arrow-left" type="button" data-gallery-prev aria-label="Предыдущее изображение">&#10094;</button>
                                    <div class="work-image-track" data-gallery-track>
                                        <% profileImages.forEach((imageUrl, idx) => { %>
                                            <div class="work-image">
                                                <img src="<%= imageUrl %>" alt="<%= work.title %> — изображение <%= idx + 1 %>" loading="lazy" decoding="async" onerror="this.onerror=null;this.src='/img/work_img.svg';">
                                            </div>
                                        <% }) %>
                                    </div>
                                    <button class="gallery-arrow gallery-arrow-right" type="button" data-gallery-next aria-label="Следующее изображение">&#10095;</button>
                                </div>
                                <div class="work-info">
                                    <h3><%= work.title %></h3>
                                    <div class="work-tegs">
                                        <% if (work.categories && work.categories.length) { %>
                                            <% work.categories.forEach((categoryName) => { %>
                                                <div class="teg"><p><%= categoryName %></p></div>
                                            <% }) %>
                                        <% } else { %>
                                            <div class="teg"><p>Без категории</p></div>
                                        <% } %>
                                    </div>
                                    <div class="work-stats">
                                        <button class="post-like-btn <%= work.is_liked ? 'is-liked' : '' %>" data-work-id="<%= work.id %>" data-liked="<%= work.is_liked ? 'true' : 'false' %>">
                                            <svg width="20" height="20" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                <path d="M16 28C15.5985 27.9995 15.2065 27.8782 14.875 27.6519C9.96309 24.3175 7.83621 22.0312 6.66309 20.6019C4.16309 17.555 2.96621 14.4269 2.99996 11.0394C3.03934 7.1575 6.15371 4 9.94246 4C12.6975 4 14.6056 5.55188 15.7168 6.84438C15.752 6.88491 15.7955 6.91741 15.8444 6.93968C15.8932 6.96195 15.9463 6.97348 16 6.97348C16.0536 6.97348 16.1067 6.96195 16.1555 6.93968C16.2044 6.91741 16.2479 6.88491 16.2831 6.84438C17.3943 5.55063 19.3025 4 22.0575 4C25.8462 4 28.9606 7.1575 29 11.04C29.0337 14.4281 27.8356 17.5563 25.3368 20.6025C24.1637 22.0319 22.0368 24.3181 17.125 27.6525C16.7933 27.8786 16.4013 27.9997 16 28Z" fill="none" stroke="#696969" stroke-width="3px"/>
                                            </svg>
 
                                            <span class="post-like-count"><%= work.likes || 0 %></span>
                                        </button>
                                        <span><%= new Date(work.created_at).toLocaleDateString('ru-RU') %></span>
                                    </div>
                                    <button class="view-work-btn" type="button" data-open-work>
                                        <svg width="9" height="8" viewBox="0 0 12 11" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <path d="M0.323242 9.83333L11.3232 0.5M11.3232 0.5V10.5M11.3232 0.5H1.01074" stroke="#535D5A"/>
                                        </svg>
                                        <p>Просмотреть работу</p>
                                    </button>
                                    <% if (!isOwnProfile) { %>
                                        <button class="profile-complain-btn btn-complain" type="button" data-work-id="<%= work.id %>">
                                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                <path class="svg-hover" d="M12 22C14.7614 22 17.2614 20.8807 19.0711 19.0711C20.8807 17.2614 22 14.7614 22 12C22 9.2386 20.8807 6.7386 19.0711 4.92893C17.2614 3.11929 14.7614 2 12 2C9.2386 2 6.7386 3.11929 4.92893 4.92893C3.11929 6.7386 2 9.2386 2 12C2 14.7614 3.11929 17.2614 4.92893 19.0711C6.7386 20.8807 9.2386 22 12 22Z" fill="#292929"/>
                                                <path fill-rule="evenodd" clip-rule="evenodd" d="M12 18.5C12.6904 18.5 13.25 17.9404 13.25 17.25C13.25 16.5597 12.6904 16 12 16C11.3097 16 10.75 16.5597 10.75 17.25C10.75 17.9404 11.3097 18.5 12 18.5Z" fill="white"/>
                                                <path d="M12 6V14" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                            </svg>
                                        </button>
                                    <% } %>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>
            <div class="profile-header">
                <div class="profile-avatar">
                    <img src="<%= profileUser.avatar || '/img/Group.svg' %>" alt="Аватар">
                </div>
                 

                <div class="profile-info">
                    <h1><%= profileUser.first_name %> <%= profileUser.last_name %></h1>
                    <p class="profile-email"><%= profileUser.email %></p>
                    <% if (!isOwnProfile) { %>
                        <button class="subscribe-btn" data-user-id="<%= profileUser.id %>" data-subscribed="<%= isSubscribed ? 'true' : 'false' %>">
                            <%= isSubscribed ? 'Отписаться' : 'Подписаться' %>
                        </button>
                    <% } else { %>
                        <div class="profile-actions">
                            <a href="/settings" class="edit-profile-btn">Настройки</a>
                            <a href="/works/create" class="create-work-btn">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M12.75 7C12.75 6.58579 12.4142 6.25 12 6.25C11.5858 6.25 11.25 6.58579 11.25 7V11.25H7C6.58579 11.25 6.25 11.5858 6.25 12C6.25 12.4142 6.58579 12.75 7 12.75H11.25V17C11.25 17.4142 11.5858 17.75 12 17.75C12.4142 17.75 12.75 17.4142 12.75 17V12.75H17C17.4142 12.75 17.75 12.4142 17.75 12C17.75 11.5858 17.4142 11.25 17 11.25H12.75V7Z" fill="white"/>
                                </svg>
                            </a>
                        </div>
                    <% } %>
                    <div class="profile-stats">
                        <div class="stat">
                            <span class="stat-value"><%= profileUser.avg_rating %></span>
                            <span class="stat-label">Рейтинг</span>
                        </div>
                        <div class="stat">
                            <span class="stat-value"><%= followersCount %></span>
                            <span class="stat-label">Подписчиков</span>
                        </div>
                        <div class="stat">
                            <span class="stat-value"><%= works.length %></span>
                            <span class="stat-label">Работ</span>
                        </div>
                    </div>
                    <% if (!isOwnProfile) { %>
                    
                    <% } else { %>
                        <div class="count-prof">
                            <div class="cont">
                                <p><%= Number(currentUser.total_balance || 0).toLocaleString('ru-RU') %></p>
                                <svg width="17" height="20" viewBox="0 0 17 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M1.87573 19.9919V-5.79357e-05H8.79173C11.3304 -5.79357e-05 13.2251 0.550609 14.4757 1.65194C15.7451 2.75328 16.3797 4.32128 16.3797 6.35594C16.3797 7.51328 16.1371 8.60528 15.6517 9.63194C15.1851 10.6399 14.4011 11.4613 13.2997 12.0959C12.1984 12.7306 10.6957 13.0573 8.79173 13.0759H7.27973V19.9919H1.87573ZM-0.000273418 18.1999V14.9239H10.7797V18.1999H-0.000273418ZM-0.000273418 13.0759V8.67994H8.20373V13.0759H-0.000273418ZM8.25973 8.67994C8.72639 8.67994 9.15573 8.59594 9.54773 8.42794C9.95839 8.25994 10.2851 8.00794 10.5277 7.67194C10.7891 7.31728 10.9197 6.88794 10.9197 6.38394C10.9197 5.74928 10.7424 5.25461 10.3877 4.89994C10.0331 4.54528 9.46373 4.36794 8.67973 4.36794H7.27973V8.67994H8.25973Z" fill="white"/>
                                </svg>
                            </div>
                            <button class="plus_count">Пополнить</button>
                        </div>
                    <% } %>

                </div>
            </div>
        </div>
    </main>

    <div id="workViewerModal" class="work-viewer-modal" aria-hidden="true">
        <div class="work-viewer-overlay" data-close-work-viewer></div>
        <div class="work-viewer-content" role="dialog" aria-modal="true" aria-label="Просмотр работы">
            <button class="work-viewer-close" type="button" data-close-work-viewer aria-label="Закрыть">&times;</button>
            <h3 id="workViewerTitle"></h3>
            <div class="work-viewer-gallery" data-viewer-gallery>
                <button class="gallery-arrow gallery-arrow-left" type="button" data-viewer-prev aria-label="Предыдущее изображение">&#10094;</button>
                <div class="work-viewer-track" id="workViewerTrack"></div>
                <button class="gallery-arrow gallery-arrow-right" type="button" data-viewer-next aria-label="Следующее изображение">&#10095;</button>
            </div>
            <div class="work-viewer-dots" id="workViewerDots"></div>
            <p id="workViewerDescription"></p>
            <div id="workViewerStats" class="work-stats"></div>
        </div>
    </div>

    <div id="deleteWorkModal" class="delete-work-modal" aria-hidden="true">
        <div class="delete-work-modal-overlay" data-close-delete-modal></div>
        <div class="delete-work-modal-content" role="dialog" aria-modal="true" aria-labelledby="deleteWorkModalTitle">
            <button class="delete-work-modal-close" type="button" data-close-delete-modal aria-label="Закрыть">&times;</button>
            <h2 id="deleteWorkModalTitle">Удалить работу</h2>
            <form class="delete-work-form" id="deleteWorkForm">
                <div class="delete-work-form-group">
                    <p class="delete-work-modal-text">
                        Вы уверены, что хотите удалить эту работу? <br>Действие нельзя отменить.
                    </p>
                </div>
                <p class="delete-work-validation-error" id="deleteWorkValidationError" role="alert" style="display:none;"></p>
                <button type="submit" class="delete-work-submit-btn">Удалить</button>
            </form>
            <div class="report-success-state" id="deleteWorkSuccessState">
                <div class="success-content" role="status">
                    <svg width="170" height="236" viewBox="0 0 170 236" fill="none" xmlns="http://www.w3.org/2000/svg">
