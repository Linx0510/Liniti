94H81.79H153.993L153.555 154.982ZM150.048 173.805C150.048 174.459 130.197 283.662 129.32 287.641C128.882 289.718 128.13 291.204 126.815 292.391L124.937 294.113L82.9798 294.291C36.389 294.469 37.5788 294.528 35.7001 290.61C35.1992 289.6 30.1894 263.234 24.4908 232.059C18.7922 200.883 14.0329 174.875 13.9076 174.281C13.6572 173.331 17.2266 173.271 81.8527 173.271C119.363 173.271 150.048 173.509 150.048 173.805Z" fill="#CF2F2F" fill-opacity="0.5"/>
                            <path d="M113.289 201.834C112.537 202.071 111.536 202.903 110.972 203.675C110.409 204.565 108.656 215.017 106.15 232.237L102.268 259.435L103.52 261.037C104.522 262.343 105.273 262.641 107.465 262.641C112.036 262.641 111.911 262.997 116.295 232.475L120.178 205.277L118.925 203.675C117.548 201.893 115.231 201.122 113.289 201.834Z" fill="#CF2F2F" fill-opacity="0.5"/>
                            <path d="M46.1588 203.318C45.4699 204.209 44.8438 205.338 44.8438 205.812C44.8438 206.346 46.5345 218.639 48.601 233.187C52.8594 262.937 52.7967 262.641 57.3681 262.641C59.5599 262.641 60.3114 262.344 61.3133 261.037L62.5657 259.434L58.6832 232.237C54.3623 202.012 54.4248 202.19 50.0413 201.893C47.9122 201.716 47.2859 201.953 46.1588 203.318Z" fill="#CF2F2F" fill-opacity="0.5"/>
