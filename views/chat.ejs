<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Сообщения | LineStok</title>
    <link rel="stylesheet" href="/css/chat.css">
    <link rel="stylesheet" href="/css/header.css">
</head>
<body>
    <main>
        <%- include('partials/header-actions') %>

        <div class="chat-container">
            <div class="chat-sidebar">
                <div class="chat-search">
                    <input type="text" placeholder="Поиск пользователей..." id="searchChats">
                </div>
                <div class="chat-list" id="chatList">
                    <div class="loading">Загрузка...</div>
                </div>
            </div>

            <div class="chat-main" id="chatMain" style="display: none;">
                <div class="chat-header" id="chatHeader"></div>

                <div class="chat-messages" id="chatMessages"></div>

                <div class="chat-input-area">
                    <button id="attachFileBtn" class="attach-btn" type="button" title="Прикрепить файл">📎</button>
                    <input type="file" id="messageFileInput" class="file-hidden-input">
                    <div class="input-stack">
                        <textarea id="messageInput" placeholder="Введите сообщение..." rows="3"></textarea>
                        <div id="selectedFileName" class="selected-file" style="display:none;"></div>
                    </div>
                    <button id="sendMessageBtn" class="send-btn">Отправить</button>
                </div>
            </div>

            <div class="chat-empty" id="chatEmpty">
                <svg width="100" height="100" viewBox="0 0 100 100" fill="none">
                    <circle cx="50" cy="50" r="45" stroke="#ddd" stroke-width="2" fill="none"/>
                    <path d="M30 35H70M30 50H55M30 65H45" stroke="#ddd" stroke-width="2" stroke-linecap="round"/>
                </svg>
                <p>Выберите чат для начала общения</p>
            </div>
        </div>
    </main>

    <script>
        const csrfToken = '<%= csrfToken %>';
        let currentChatId = null;
        let messagePollingInterval = null;
        let chatsCache = [];
        let searchTimeout = null;

        async function loadChats() {
            const response = await fetch('/api/chats');
            const chats = await response.json();
            chatsCache = Array.isArray(chats) ? chats : [];
            renderChats(chatsCache);
        }

        function renderChats(chats) {
            const container = document.getElementById('chatList');

            if (chats.length === 0) {
                container.innerHTML = '<div class="empty-chats">Нет чатов</div>';
                return;
            }

            container.innerHTML = chats.map(chat => `
                <div class="chat-item" data-chat-id="${chat.id}">
                    <div class="chat-avatar">
                        ${chat.otherUser.avatar
                            ? `<img src="${chat.otherUser.avatar}" alt="">`
                            : `<img src="/img/Group.svg" alt="Аватар">`
                        }
                    </div>
                    <div class="chat-info">
                        <div class="chat-name">${chat.otherUser.first_name} ${chat.otherUser.last_name}</div>
                        <div class="chat-last-message">${escapeHtml(chat.lastMessage || 'Нет сообщений')}</div>
                    </div>
                    ${chat.unreadCount > 0 ? `<div class="chat-unread">${chat.unreadCount}</div>` : ''}
                </div>
            `).join('');

            document.querySelectorAll('.chat-item').forEach(item => {
                item.addEventListener('click', () => {
                    const chatId = parseInt(item.dataset.chatId, 10);
                    openChat(chatId);
                });
            });
        }

        async function searchUsers(query) {
            const response = await fetch(`/api/chats/search/users?q=${encodeURIComponent(query)}`);
            if (!response.ok) return [];
            return response.json();
        }

        function renderUserResults(users) {
            const container = document.getElementById('chatList');

            if (users.length === 0) {
                container.innerHTML = '<div class="empty-chats">Пользователи не найдены</div>';
                return;
            }

            container.innerHTML = users.map(user => `
                <div class="chat-item chat-user-item" data-user-id="${user.id}" data-chat-id="${user.chatId || ''}">
                    <div class="chat-avatar">
                        ${user.avatar
                            ? `<img src="${user.avatar}" alt="">`
                            : `<img src="/img/Group.svg" alt="Аватар">`
                        }
                    </div>
                    <div class="chat-info">
                        <div class="chat-name">${user.first_name} ${user.last_name}</div>
                        <div class="chat-last-message">${user.chatId ? 'Открыть чат' : 'Начать диалог'}</div>
                    </div>
                </div>
            `).join('');

            document.querySelectorAll('.chat-user-item').forEach(item => {
                item.addEventListener('click', async () => {
                    const userId = parseInt(item.dataset.userId, 10);
                    const response = await fetch(`/api/chats/user/${userId}`);
                    const data = await response.json();
                    if (!response.ok || !data.chatId) return;
                    await loadChats();
                    openChat(data.chatId);
                });
            });
        }

        async function openChat(chatId) {
            currentChatId = chatId;

            const messagesResponse = await fetch(`/api/chats/${chatId}/messages`);
            const messages = await messagesResponse.json();

            const chatItem = document.querySelector(`.chat-item[data-chat-id="${chatId}"]`);
            const otherUserName = chatItem.querySelector('.chat-name').textContent;

            document.getElementById('chatHeader').innerHTML = `
                <div class="chat-user-info">
                    <div class="chat-avatar">
                        ${chatItem.querySelector('.chat-avatar img')
                            ? chatItem.querySelector('.chat-avatar').innerHTML
                            : `<img src="/img/Group.svg" alt="Аватар">`
                        }
                    </div>
                    <div class="chat-user-name">${otherUserName}</div>
                </div>
            `;

            displayMessages(messages);

            document.getElementById('chatMain').style.display = 'flex';
            document.getElementById('chatEmpty').style.display = 'none';

            const draftResponse = await fetch(`/api/chats/${chatId}/draft`);
            const draft = await draftResponse.json();
            document.getElementById('messageInput').value = draft.draft_text || '';
            clearSelectedFile();

            if (messagePollingInterval) clearInterval(messagePollingInterval);
            messagePollingInterval = setInterval(() => {
                if (currentChatId) refreshMessages(currentChatId);
            }, 3000);
        }

        function displayMessages(messages) {
            const container = document.getElementById('chatMessages');
            const currentUserId = Number('<%= currentUser.id %>');

            container.innerHTML = messages.map(msg => {
                const textHtml = msg.message ? `<div class="message-content">${escapeHtml(msg.message)}</div>` : '';
                const fileHtml = msg.file_url
                    ? `<a class="message-file" href="${msg.file_url}" target="_blank" rel="noopener noreferrer">📎 ${escapeHtml(msg.file_name || 'Файл')}</a>`
                    : '';

                return `
                    <div class="message ${msg.sender_id === currentUserId ? 'message-out' : 'message-in'}">
                        ${textHtml}
                        ${fileHtml}
                        <div class="message-time">${new Date(msg.created_at).toLocaleTimeString()}</div>
                    </div>
                `;
            }).join('');

            container.scrollTop = container.scrollHeight;
        }

        async function refreshMessages(chatId) {
            const response = await fetch(`/api/chats/${chatId}/messages`);
            const messages = await response.json();
            displayMessages(messages);
            loadChats();
        }

        async function sendMessage() {
            if (!currentChatId) return;

            const input = document.getElementById('messageInput');
            const fileInput = document.getElementById('messageFileInput');
            const message = input.value.trim();
            const selectedFile = fileInput.files[0];

            if (!message && !selectedFile) return;

            let response;

            if (selectedFile) {
                const formData = new FormData();
                formData.append('file', selectedFile);
                formData.append('message', message);
                formData.append('csrf_token', csrfToken);

                response = await fetch(`/api/chats/${currentChatId}/files`, {
                    method: 'POST',
                    body: formData,
                });
            } else {
                response = await fetch(`/api/chats/${currentChatId}/messages`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'x-csrf-token': csrfToken,
                    },
                    body: JSON.stringify({ message }),
                });
            }

            if (response.ok) {
                input.value = '';
                clearSelectedFile();
                await refreshMessages(currentChatId);

                await fetch(`/api/chats/${currentChatId}/draft`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'x-csrf-token': csrfToken,
                    },
                    body: JSON.stringify({ draft_text: '' }),
                });
            }
        }

        function clearSelectedFile() {
            const fileInput = document.getElementById('messageFileInput');
            const selectedFileName = document.getElementById('selectedFileName');
            fileInput.value = '';
            selectedFileName.textContent = '';
            selectedFileName.style.display = 'none';
        }

        let draftTimeout;
        document.getElementById('messageInput')?.addEventListener('input', () => {
            if (!currentChatId) return;

            clearTimeout(draftTimeout);
            draftTimeout = setTimeout(async () => {
                const draftText = document.getElementById('messageInput').value;
                await fetch(`/api/chats/${currentChatId}/draft`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'x-csrf-token': csrfToken,
                    },
                    body: JSON.stringify({ draft_text: draftText }),
                });
            }, 1000);
        });

        document.getElementById('messageInput')?.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' && !e.ctrlKey && !e.shiftKey) {
                e.preventDefault();
                sendMessage();
            }
        });

        document.getElementById('sendMessageBtn')?.addEventListener('click', sendMessage);
        document.getElementById('attachFileBtn')?.addEventListener('click', () => {
            document.getElementById('messageFileInput').click();
        });

        document.getElementById('messageFileInput')?.addEventListener('change', (e) => {
            const file = e.target.files?.[0];
            const selectedFileName = document.getElementById('selectedFileName');

            if (!file) {
                clearSelectedFile();
                return;
            }

            selectedFileName.textContent = `Выбран файл: ${file.name}`;
            selectedFileName.style.display = 'block';
        });

        document.getElementById('searchChats')?.addEventListener('input', (e) => {
            const search = e.target.value.trim();
            clearTimeout(searchTimeout);

            if (search.length < 2) {
                renderChats(chatsCache);
                return;
            }

            searchTimeout = setTimeout(async () => {
                const users = await searchUsers(search);
                renderUserResults(users);
            }, 250);
        });

        function escapeHtml(str) {
            return String(str).replace(/[&<>\"]/g, function(m) {
                if (m === '&') return '&amp;';
                if (m === '<') return '&lt;';
                if (m === '>') return '&gt;';
                if (m === '"') return '&quot;';
                return m;
            });
        }

        loadChats();

        window.addEventListener('beforeunload', () => {
            if (messagePollingInterval) clearInterval(messagePollingInterval);
        });
    </script>
</body>
</html>
