<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Вход и регистрация</title>
  <link rel="stylesheet" href="/css/aut_reg.css" />
</head>
<body>
  <main>
    <div class="box-content" id="authRoot" data-initial-mode="<%= mode || 'login' %>">
      <section class="login-container" id="loginContainer">
        <div class="container">
          <div class="cards">
            <h2>Вход</h2>
            <% if (error) { %>
              <p class="error-message" style="display:block;"><%= error %></p>
            <% } %>
            <% if (success) { %>
              <p style="color:#1f8f4a;font-family:'Montserrat';font-size:12px;"><%= success %></p>
            <% } %>
            <form method="post" action="/login" novalidate>
              <div class="form-group">
                <label for="loginEmail">Email</label>
                <input id="loginEmail" type="email" name="email" placeholder="Введите email" required />
                <span class="error-message">Введите корректный email</span>
              </div>
              <div class="form-group">
                <label for="loginPassword">Пароль</label>
                <input id="loginPassword" type="password" name="password" placeholder="Введите пароль" required minlength="6" />
                <span class="error-message">Пароль должен быть не менее 6 символов</span>
              </div>
              <button class="form_button_back" type="submit">Войти</button>
            </form>
          </div>
        </div>
      </section>

      <section class="register-container" id="registerContainer">
        <div class="container">
          <div class="cards">
            <h2>Регистрация</h2>
            <form method="post" action="/register" novalidate>
              <div class="form-group">
                <label for="registerFirstName">Имя</label>
                <input id="registerFirstName" type="text" name="first_name" placeholder="Введите имя" required />
                <span class="error-message">Введите имя</span>
              </div>
              <div class="form-group">
                <label for="registerLastName">Фамилия</label>
                <input id="registerLastName" type="text" name="last_name" placeholder="Введите фамилию" required />
                <span class="error-message">Введите фамилию</span>
              </div>
              <div class="form-group">
                <label for="registerEmail">Email</label>
                <input id="registerEmail" type="email" name="email" placeholder="Введите email" required />
                <span class="error-message">Введите корректный email</span>
              </div>
              <div class="form-group">
                <label for="registerPassword">Пароль</label>
                <input id="registerPassword" type="password" name="password" placeholder="Создайте пароль" required minlength="6" />
                <span class="error-message">Пароль должен быть не менее 6 символов</span>
              </div>
              <div class="form-group">
                <label for="registerConfirmPassword">Повторите пароль</label>
                <input id="registerConfirmPassword" type="password" name="confirm_password" placeholder="Повторите пароль" required minlength="6" />
                <span class="error-message">Пароли не совпадают</span>
              </div>
              <button class="form_button_back" type="submit">Зарегистрироваться</button>
            </form>
          </div>
        </div>
      </section>

      <aside class="contaner_page" id="authPanel">
        <div class="cont_header" id="panelHeader">
          <h1 id="panelTitle">Добро пожаловать</h1>
          <p id="panelText">Войдите в аккаунт, чтобы продолжить работу на платформе</p>
        </div>
        <button class="main_button" type="button" id="toggleAuthMode">Создать аккаунт</button>
      </aside>
    </div>
  </main>

  <script src="/js/auth.js"></script>
</body>
</html>
