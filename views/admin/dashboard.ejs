<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Админ-панель | LineStok</title>
    <link rel="stylesheet" href="/css/admin.css">
    <link rel="stylesheet" href="/css/header.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
    <main>
        <%- include('../partials/header-actions') %>
    <section class="admin-container">
        <%- include('admin-sidebar', { currentPath: '/admin/dashboard' }) %>

        <div class="admin-main">
            <div class="admin-header">
                <h1>Дашборд</h1>
                <div class="admin-user">
                    <span><%= currentUser.first_name %> <%= currentUser.last_name %></span>
                    <form action="/logout" method="post" class="logout-form">
                        <input type="hidden" name="csrf_token" value="<%= csrfToken %>">
                        <button type="submit" class="logout-btn">
                            Выйти</button
    
                    ></form>
                </div>
            </div>

            <div class="stats-grid">
                <div class="stat-card"><div class="stat-info"><h3><%= stats.total_users %></h3><p>Пользователи</p></div></div>
                <div class="stat-card"><div class="stat-info"><h3><%= stats.total_works %></h3><p>Работы</p></div></div>
                <div class="stat-card"><div class="stat-info"><h3><%= stats.total_orders %></h3><p>Заказы</p></div></div>
                <div class="stat-card"><div class="stat-info"><h3><%= stats.pending_complaints %></h3><p>Жалобы</p></div></div>
                <div class="stat-card"><div class="stat-info"><h3><%= stats.active_orders %></h3><p>Активные заказы</p></div></div>
                <div class="stat-card"><div class="stat-info"><h3><%= Number(stats.total_revenue || 0).toLocaleString('ru-RU') %> ₽</h3><p>Выручка</p></div></div>
            </div>

            <div class="charts-grid">
                <div class="chart-card">
                    <h3>Динамика за 30 дней</h3>
                    <canvas id="activityChart"></canvas>
                </div>
            </div>

            <div class="recent-activity">
                <h3>Последние действия</h3>
                <table class="activity-table">
                    <thead><tr><th>Пользователь</th><th>Действие</th><th>Детали</th><th>Время</th></tr></thead>
                    <tbody>
                    <% recentActivities.forEach(activity => { %>
                        <tr>
                            <td><%= activity.first_name || 'Система' %> <%= activity.last_name || '' %><small><%= activity.email || '' %></small></td>
                            <td><%= activity.action %></td>
                            <td><%= activity.details ? JSON.stringify(activity.details) : '-' %></td>
                            <td><%= new Date(activity.created_at).toLocaleString('ru-RU') %></td>
                        </tr>
                    <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </section>
    </main>

    <script>
        const ctx = document.getElementById('activityChart').getContext('2d');
        const dailyStats = <%- JSON.stringify(dailyStats || []) %>;

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: dailyStats.map(s => new Date(s.date).toLocaleDateString('ru-RU')).reverse(),
                datasets: [
                    {
                        label: 'Новые пользователи',
                        data: dailyStats.map(s => s.new_users || 0).reverse(),
                        borderColor: '#FA51A2',
                        backgroundColor: 'rgba(250, 81, 162, 0.1)',
                        tension: 0.3,
                        fill: true
                    },
                    {
                        label: 'Всего заказов',
                        data: dailyStats.map(s => s.total_orders || 0).reverse(),
                        borderColor: '#7B46F8',
                        backgroundColor: 'rgba(123, 70, 248, 0.1)',
                        tension: 0.3,
                        fill: true
                    }
                ]
            },
            options: { responsive: true, maintainAspectRatio: false }
        });
    </script>
</body>
</html>
