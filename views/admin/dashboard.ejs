<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Админ-панель | LineStok</title>
    <link rel="stylesheet" href="/css/admin.css">
    <link rel="stylesheet" href="/css/header.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
    <div class="admin-container">
        <!-- Sidebar -->
        <aside class="admin-sidebar">
            <div class="admin-logo">
                <h2>LineStok Admin</h2>
            </div>
            <nav class="admin-nav">
                <a href="/admin/dashboard" class="nav-item active">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                        <path d="M3 3h6v6H3V3zm8 0h6v6h-6V3zm0 8h6v6h-6v-6zM3 11h6v6H3v-6z"/>
                    </svg>
                    <span>Дашборд</span>
                </a>
                <a href="/admin/users" class="nav-item">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                        <path d="M10 10c-2.8 0-5-2.2-5-5s2.2-5 5-5 5 2.2 5 5-2.2 5-5 5zm0 2c-3.3 0-10 1.7-10 5v3h20v-3c0-3.3-6.7-5-10-5z"/>
                    </svg>
                    <span>Пользователи</span>
                </a>
                <a href="/admin/works" class="nav-item">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                        <path d="M17 3H3c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 12H3V5h14v10zM5 7h10v2H5V7zm0 4h6v2H5v-2z"/>
                    </svg>
                    <span>Работы</span>
                </a>
                <a href="/admin/complaints" class="nav-item">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                        <path d="M10 0C4.5 0 0 4.5 0 10s4.5 10 10 10 10-4.5 10-10S15.5 0 10 0zm1 15H9v-2h2v2zm0-4H9V5h2v6z"/>
                    </svg>
                    <span>Жалобы</span>
                </a>
                <a href="/admin/export" class="nav-item">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                        <path d="M13 9V3H7v6H3l7 7 7-7h-4zM3 18h14v2H3v-2z"/>
                    </svg>
                    <span>Экспорт</span>
                </a>
            </nav>
        </aside>
        
        <!-- Main Content -->
        <main class="admin-main">
            <div class="admin-header">
                <h1>Дашборд</h1>
                <div class="admin-user">
                    <span><%= currentUser.first_name %> <%= currentUser.last_name %></span>
                    <form action="/logout" method="post" class="logout-form"><input type="hidden" name="csrf_token" value="<%= csrfToken %>"><button type="submit" class="logout-btn">Выйти</button></form>
                </div>
            </div>
            
            <!-- Statistics Cards -->
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon users-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                        </svg>
                    </div>
                    <div class="stat-info">
                        <h3><%= stats.total_users %></h3>
                        <p>Всего пользователей</p>
                        <span class="stat-change positive">+<%= stats.new_users_today %> сегодня</span>
                    </div>
                </div>
                
                <div class="stat-card">
                    <div class="stat-icon works-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M4 6h16v2H4V6zm0 4h16v2H4v-2zm0 4h10v2H4v-2zm13 0h3v2h-3v-2zm-3-4h6v2h-6v-2zM4 18h16v2H4v-2z"/>
                        </svg>
                    </div>
                    <div class="stat-info">
                        <h3><%= stats.total_works %></h3>
                        <p>Всего работ</p>
                        <span class="stat-change">+<%= stats.new_works_today ?> сегодня</span>
                    </div>
                </div>
                
                <div class="stat-card">
                    <div class="stat-icon orders-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M19 3h-4.18C14.4 1.84 13.3 1 12 1c-1.3 0-2.4.84-2.82 2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 0c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm0 4c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/>
                        </svg>
                    </div>
                    <div class="stat-info">
                        <h3><%= stats.total_orders %></h3>
                        <p>Всего заказов</p>
                        <span class="stat-change"><%= stats.active_orders %> активных</span>
                    </div>
                </div>
                
                <div class="stat-card">
                    <div class="stat-icon revenue-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"/>
                        </svg>
                    </div>
                    <div class="stat-info">
                        <h3><%= stats.total_revenue.toLocaleString() %> ₽</h3>
                        <p>Общая выручка</p>
                    </div>
                </div>
                
                <div class="stat-card">
                    <div class="stat-icon complaints-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
                        </svg>
                    </div>
                    <div class="stat-info">
                        <h3><%= stats.pending_complaints %></h3>
                        <p>Жалоб на модерации</p>
                    </div>
                </div>
            </div>
            
            <!-- Charts -->
            <div class="charts-grid">
                <div class="chart-card">
                    <h3>Динамика за последние 30 дней</h3>
                    <canvas id="activityChart"></canvas>
                </div>
            </div>
            
            <!-- Recent Activity -->
            <div class="recent-activity">
                <h3>Последние действия</h3>
                <table class="activity-table">
                    <thead>
                        <tr>
                            <th>Пользователь</th>
                            <th>Действие</th>
                            <th>Детали</th>
                            <th>Время</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% recentActivities.forEach(activity => { %>
                            <tr>
                                <td>
                                    <%= activity.first_name %> <%= activity.last_name %>
                                    <small><%= activity.email %></small>
                                </td>
                                <td><%= activity.action %></td>
                                <td><%= JSON.stringify(activity.details) %></td>
                                <td><%= new Date(activity.created_at).toLocaleString('ru-RU') %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </main>
    </div>
    
    <script>
        // График активности
        const ctx = document.getElementById('activityChart').getContext('2d');
        const dailyStats = '<%- JSON.stringify(dailyStats) %>';
        
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: dailyStats.map(s => s.date).reverse(),
                datasets: [
                    {
                        label: 'Новые пользователи',
                        data: dailyStats.map(s => s.new_users).reverse(),
                        borderColor: '#FA51A2',
                        backgroundColor: 'rgba(250, 81, 162, 0.1)',
                        tension: 0.4,
                        fill: true
                    },
                    {
                        label: 'Новые работы',
                        data: dailyStats.map(s => s.total_works).reverse(),
                        borderColor: '#7B46F8',
                        backgroundColor: 'rgba(123, 70, 248, 0.1)',
                        tension: 0.4,
                        fill: true
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'top'
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            stepSize: 1
                        }
                    }
                }
            }
        });
    </script>
</body>
</html>