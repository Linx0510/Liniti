<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Работы | Admin</title>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
<div class="admin-container">
  <%- include('admin-sidebar', { currentPath: '/admin/works' }) %>
  <main class="admin-main">
    <div class="admin-header"><h1>Модерация работ</h1></div>
    <section class="content-card">
      <form class="filters" method="get" action="/admin/works">
        <input type="text" name="search" placeholder="Поиск по работам" value="<%= search || '' %>">
        <select name="status">
          <option value="all">Все статусы</option>
          <option value="pending" <%= status==='pending'?'selected':'' %>>pending</option>
          <option value="approved" <%= status==='approved'?'selected':'' %>>approved</option>
          <option value="blocked" <%= status==='blocked'?'selected':'' %>>blocked</option>
        </select>
        <button type="submit" class="primary-btn">Фильтровать</button>
      </form>
      <table class="activity-table">
        <thead><tr><th>ID</th><th>Работа</th><th>Автор</th><th>Жалобы</th><th>Статус</th><th>Действия</th></tr></thead>
        <tbody>
        <% works.forEach(work => { %>
          <tr>
            <td><%= work.id %></td>
            <td><strong><%= work.title %></strong><small><%= (work.description || '').slice(0, 90) %></small></td>
            <td><%= work.first_name %> <%= work.last_name %></td>
            <td><%= work.complaints_count %></td>
            <td><span class="status-badge status-<%= work.status %>"><%= work.status %></span></td>
            <td>
              <form method="post" action="/admin/works/<%= work.id %>/moderate" class="inline-form"><input type="hidden" name="csrf_token" value="<%= csrfToken %>"><input type="hidden" name="status" value="approved"><button class="small-btn">Одобрить</button></form>
              <form method="post" action="/admin/works/<%= work.id %>/moderate" class="inline-form"><input type="hidden" name="csrf_token" value="<%= csrfToken %>"><input type="hidden" name="status" value="blocked"><input type="hidden" name="reason" value="Нарушение"><button class="small-btn danger-btn">Блок</button></form>
            </td>
          </tr>
        <% }) %>
        </tbody>
      </table>
    </section>
  </main>
</div>
</body>
</html>
