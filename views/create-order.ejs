<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Добавить заказ | LineStok</title>
    <link rel="stylesheet" href="/css/orders.css">
    <link rel="stylesheet" href="/css/header.css">
</head>
<body>
    <main>
        <%- include('partials/header-actions') %>

        <section class="create-order-page">
            <div class="create-order-card">
                <h1>Добавление заказа</h1>
                <p class="create-order-subtitle">Опишите задачу и укажите бюджет, чтобы начать сотрудничество.</p>

                <form id="createOrderForm" class="create-order-form">
                    <input type="hidden" name="csrf_token" value="<%= csrfToken %>">

                    <label for="title">Название заказа *</label>
                    <input id="title" name="title" type="text" maxlength="120" required placeholder="Например, дизайн лендинга">

                    <label for="description">Описание</label>
                    <textarea id="description" name="description" rows="6" maxlength="2000" placeholder="Опишите детали заказа, дедлайн и ожидания"></textarea>

                    <label for="price">Цена, ₽ *</label>
                    <input id="price" name="price" type="number" min="1" step="1" required placeholder="15000">

                    <label for="startDate">Дата старта (необязательно)</label>
                    <input id="startDate" name="start_date" type="date">

                    <label for="deadline">Дедлайн (необязательно)</label>
                    <input id="deadline" name="deadline" type="date">

                    <label for="categoryId">ID категории (необязательно)</label>
                    <input id="categoryId" name="category_id" type="number" min="1" step="1" placeholder="Например, 3">

                    <label for="executorId">ID исполнителя (необязательно)</label>
                    <input id="executorId" name="executor_id" type="number" min="1" step="1" placeholder="Если уже выбрали исполнителя">

                    <div class="create-order-actions">
                        <a class="secondary-btn" href="/orders">Назад к заказам</a>
                        <button class="primary-btn" type="submit">Создать заказ</button>
                    </div>

                    <p class="form-message" id="formMessage"></p>
                </form>
            </div>
        </section>
    </main>

    <script>
        const form = document.getElementById('createOrderForm');
        const message = document.getElementById('formMessage');
        const csrfToken = '<%= csrfToken %>';

        form.addEventListener('submit', async (event) => {
            event.preventDefault();

            const formData = new FormData(form);
            const payload = {
                title: (formData.get('title') || '').toString().trim(),
                description: (formData.get('description') || '').toString().trim(),
                price: Number(formData.get('price') || 0),
                executor_id: formData.get('executor_id') ? Number(formData.get('executor_id')) : null,
                start_date: formData.get('start_date') ? formData.get('start_date').toString() : null,
                deadline: formData.get('deadline') ? formData.get('deadline').toString() : null,
                category_id: formData.get('category_id') ? Number(formData.get('category_id')) : null
            };

            message.textContent = '';

            if (!payload.title || !payload.price || payload.price <= 0) {
                message.textContent = 'Заполните название и корректную стоимость.';
                message.className = 'form-message is-error';
                return;
            }

            try {
                const response = await fetch('/api/orders/create', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-Token': csrfToken
                    },
                    body: JSON.stringify(payload)
                });

                const data = await response.json();
                if (!response.ok) {
                    throw new Error(data.error || 'Не удалось создать заказ');
                }

                message.textContent = 'Заказ успешно создан. Перенаправляем в список заказов...';
                message.className = 'form-message is-success';
                setTimeout(() => window.location.href = '/orders', 700);
            } catch (error) {
                message.textContent = error.message || 'Ошибка при создании заказа';
                message.className = 'form-message is-error';
            }
        });
    </script>
</body>
</html>
