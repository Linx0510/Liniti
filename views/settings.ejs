<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Настройки профиля | LineStok</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/lenta_new.css">
    <link rel="stylesheet" href="/css/header.css">
    <style>
        .settings-page {
            display: flex;
            justify-content: center;
            padding: 10px 0 30px;
        }

        .settings-container {
            display: flex;
            flex-direction: column;
            gap: 20px;
            border-radius: 20px;
            background-color: #FFFFFF;
            width: min(920px, 100%);
            padding: 24px;
            box-shadow: 0 8px 24px rgba(41, 41, 41, 0.08);
        }

        .settings-head {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        .settings-title {
            font-family: 'Montserrat';
            font-size: 30px;
            font-weight: 600;
            color: #292929;
            margin: 0;
        }

        .back-btn {
            width: fit-content;
            display: inline-flex;
            gap: 8px;
            align-items: center;
            justify-content: center;
            border-radius: 20px;
            border: 0.8px solid #393939;
            background-color: #F3F7F6;
            padding: 8px 14px;
            cursor: pointer;
            text-decoration: none;
            font-family: 'Montserrat';
            font-size: 14px;
            font-weight: 600;
            color: #393939;
        }

        .back-btn:hover {
            background-color: #EBEFEF;
        }

        .settings-section {
            border: 1px solid #EBEBEB;
            border-radius: 20px;
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .settings-section h2 {
            font-family: 'Montserrat';
            font-size: 20px;
            font-weight: 700;
            color: #292929;
            margin: 0;
        }

        .form-group {
            margin-bottom: 0;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .form-group label,
        .checkbox-label span {
            font-family: 'Montserrat';
            font-size: 14px;
            font-weight: 600;
            color: #292929;
        }

        .form-group input,
        .form-group textarea {
            width: 100%;
            padding: 12px 14px;
            border: 1px solid #ddd;
            border-radius: 12px;
            font-size: 14px;
            font-family: 'Montserrat';
            color: #292929;
            background: #FFFFFF;
            outline: none;
        }

        .form-group input:focus,
        .form-group textarea:focus {
            border-color: #393939;
        }

        .form-group textarea {
            resize: vertical;
            min-height: 100px;
        }

        .avatar-preview img {
            width: 80px;
            height: 80px;
            object-fit: cover;
            border-radius: 50%;
            border: 1px solid #E1E1E1;
            margin-top: 8px;
        }

        .checkbox-label {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
        }

        .save-btn {
            width: fit-content;
            border: none;
            border-radius: 20px;
            background-color: #393939;
            color: #F3F7F6;
            padding: 12px 22px;
            font-family: 'Montserrat';
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
        }

        .save-btn:hover {
            background-color: #292929;
        }

        @media (max-width: 768px) {
            .settings-container {
                padding: 18px;
                border-radius: 16px;
            }

            .settings-title {
                font-size: 24px;
            }
        }
    </style>
</head>
<body>
    <main>
        <%- include('partials/header-actions') %>

        <div class="settings-page">
            <div class="settings-container">
                <div class="settings-head">
                    <h1 class="settings-title">Настройки профиля</h1>
                    <a class="back-btn" href="/profile">← Назад</a>
                </div>

                <form id="settingsForm" method="POST" action="/api/profile/update" enctype="multipart/form-data">
                    <input type="hidden" name="csrf_token" value="<%= csrfToken %>">

                    <div class="settings-section">
                        <h2>Личная информация</h2>

                        <div class="form-group">
                            <label for="firstName">Имя</label>
                            <input type="text" id="firstName" name="first_name" value="<%= currentUser.first_name %>" required>
                        </div>

                        <div class="form-group">
                            <label for="lastName">Фамилия</label>
                            <input type="text" id="lastName" name="last_name" value="<%= currentUser.last_name %>" required>
                        </div>

                        <div class="form-group">
                            <label for="email">Email</label>
                            <input type="email" id="email" name="email" value="<%= currentUser.email %>" required>
                        </div>

                        <div class="form-group">
                            <label for="bio">О себе</label>
                            <textarea id="bio" name="bio" rows="5"><%= currentUser.bio || '' %></textarea>
                        </div>

                        <div class="form-group">
                            <label for="avatar">Аватар</label>
                            <input type="file" id="avatar" name="avatar" accept="image/*">
                            <div class="avatar-preview">
                                <% if (currentUser.avatar) { %>
                                    <img src="<%= currentUser.avatar %>" alt="Текущий аватар">
                                <% } %>
                            </div>
                        </div>
                    </div>

                    <div class="settings-section">
                        <h2>Смена пароля</h2>

                        <div class="form-group">
                            <label for="currentPassword">Текущий пароль</label>
                            <input type="password" id="currentPassword" name="current_password">
                        </div>

                        <div class="form-group">
                            <label for="newPassword">Новый пароль</label>
                            <input type="password" id="newPassword" name="new_password">
                        </div>

                        <div class="form-group">
                            <label for="confirmPassword">Подтверждение пароля</label>
                            <input type="password" id="confirmPassword" name="confirm_password">
                        </div>
                    </div>

                    <div class="settings-section">
                        <h2>Уведомления</h2>

                        <label class="checkbox-label">
                            <input type="checkbox" name="email_notifications" <%= currentUser.email_notifications ? 'checked' : '' %>>
                            <span>Получать email-уведомления</span>
                        </label>

                        <label class="checkbox-label">
                            <input type="checkbox" name="push_notifications" <%= currentUser.push_notifications ? 'checked' : '' %>>
                            <span>Получать push-уведомления</span>
                        </label>
                    </div>

                    <button type="submit" class="save-btn">Сохранить изменения</button>
                </form>
            </div>
        </div>
    </main>

    <script>
        document.getElementById('settingsForm').addEventListener('submit', async (e) => {
            e.preventDefault();

            const formData = new FormData(e.target);

            const response = await fetch('/api/profile/update', {
                method: 'POST',
                body: formData
            });

            if (response.ok) {
                window.location.href = '/profile?profile_updated=1';
            } else {
                const error = await response.json();
                alert('Ошибка: ' + (error.error || 'Не удалось обновить профиль'));
            }
        });

        // Предпросмотр аватара
        const avatarInput = document.getElementById('avatar');
        if (avatarInput) {
            avatarInput.addEventListener('change', (e) => {
                const preview = document.querySelector('.avatar-preview');
                if (e.target.files[0]) {
                    const reader = new FileReader();
                    reader.onload = (e) => {
                        preview.innerHTML = `<img src="${e.target.result}" alt="Новый аватар">`;
                    };
                    reader.readAsDataURL(e.target.files[0]);
                }
            });
        }
    </script>
</body>
</html>
