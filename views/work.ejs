<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= work.title %> | LineStok</title>
    <link rel="stylesheet" href="/css/work.css">
    <link rel="stylesheet" href="/css/header.css">
</head>
<body>
    <main>
        <%- include('partials/header-actions') %>

        <div class="work-page-container">
            <a class="back-link" href="/lenta">← Назад в ленту</a>

            <article class="work-page-card">
                <header class="work-page-head">
                    <a href="/profile/<%= work.user_id %>" class="author-block">
                        <img src="<%= work.avatar || '/img/Group.svg' %>" alt="<%= work.first_name %> <%= work.last_name %>" loading="lazy" decoding="async">
                        <div>
                            <p class="author-name"><%= work.first_name %> <%= work.last_name %></p>
                            <p class="work-date"><%= new Date(work.created_at).toLocaleDateString('ru-RU') %></p>
                        </div>
                    </a>
                    <h1><%= work.title %></h1>
                </header>

                <section class="work-page-gallery" data-gallery>
                    <button class="gallery-arrow gallery-arrow-left" type="button" data-gallery-prev aria-label="Предыдущее изображение">&#10094;</button>
                    <div class="work-page-track" data-gallery-track>
                        <% const workImages = (work.images && work.images.length ? work.images : ['/img/work_img.svg']); %>
                        <% workImages.forEach((imageUrl, idx) => { %>
                            <div class="work-page-image">
                                <img src="<%= imageUrl %>" alt="<%= work.title %> — изображение <%= idx + 1 %>" loading="lazy" decoding="async" onerror="this.onerror=null;this.src='/img/work_img.svg';">
                            </div>
                        <% }) %>
                    </div>
                    <button class="gallery-arrow gallery-arrow-right" type="button" data-gallery-next aria-label="Следующее изображение">&#10095;</button>
                </section>

                <section class="work-page-content">
                    <h2>Описание</h2>
                    <p><%= work.description || 'Описание отсутствует.' %></p>

                    <div class="work-tags">
                        <% if (work.categories && work.categories.length) { %>
                            <% work.categories.forEach((categoryName) => { %>
                                <span class="tag"><%= categoryName %></span>
                            <% }) %>
                        <% } else { %>
                            <span class="tag">Без категории</span>
                        <% } %>
                    </div>
                </section>
            </article>
        </div>
    </main>

    <script>
        document.querySelectorAll('[data-gallery]').forEach((gallery) => {
            const track = gallery.querySelector('[data-gallery-track]');
            const prev = gallery.querySelector('[data-gallery-prev]');
            const next = gallery.querySelector('[data-gallery-next]');
            const slides = Array.from(track.children);
            if (!slides.length) return;

            let index = 0;
            const render = () => {
                track.style.transform = `translateX(-${index * 100}%)`;
                prev.disabled = slides.length <= 1 || index === 0;
                next.disabled = slides.length <= 1 || index === slides.length - 1;
            };

            prev.addEventListener('click', () => {
                if (index > 0) {
                    index -= 1;
                    render();
                }
            });

            next.addEventListener('click', () => {
                if (index < slides.length - 1) {
                    index += 1;
                    render();
                }
            });

            render();
        });
    </script>
</body>
</html>
