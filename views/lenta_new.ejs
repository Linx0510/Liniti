                { id: "electronics_devices", name: "Электроника и устройства", selected: false },
                { id: "items_accessories", name: "Предметы и аксессуары", selected: false },
                { id: "packaging_label", name: "Упаковка и этикетка", selected: false }
            ]
        }
    ];

    let filterData = JSON.parse(JSON.stringify(categoriesData));

    // Функция для пересчета состояния родительских категорий (selected и indeterminate)
    function recalcAllParents() {
        for (let cat of filterData) {
            if (cat.subcategories && cat.subcategories.length > 0) {
                const allSelected = cat.subcategories.every(sub => sub.selected === true);
                const someSelected = cat.subcategories.some(sub => sub.selected === true);
                cat.selected = allSelected;
                cat.indeterminate = someSelected && !allSelected;
            } else {
                cat.indeterminate = false;
            }
        }
    }

    // Получение списка всех выбранных элементов (с названиями и путями)
    function getSelectedItems() {
        const selected = [];
        for (let cat of filterData) {
            if (cat.subcategories && cat.subcategories.length > 0) {
                for (let sub of cat.subcategories) {
                    if (sub.selected) {
                        selected.push({
                            id: sub.id,
                            name: sub.name,
                            categoryId: cat.id,
                            categoryName: cat.name,
                            type: 'sub'
                        });
                    }
                }
            } else {
                if (cat.selected) {
                    selected.push({
                        id: cat.id,
                        name: cat.name,
                        categoryId: null,
                        categoryName: null,
                        type: 'category'
                    });
                }
            }
        }
        return selected;
    }

    // Подсчет количества выбранных элементов
    function getTotalSelectedCount() {
        return getSelectedItems().length;
    }

    // Обновление статистики и списка выбранных элементов внизу
    function updateSelectedDisplay() {
        const selectedCountSpan = document.getElementById('selectedCount');
        const selectedItemsContainer = document.getElementById('selectedItemsList');
        
        if (!selectedItemsContainer) return;
        
        const selectedItems = getSelectedItems();
        const count = selectedItems.length;
        if (selectedCountSpan) {
            selectedCountSpan.innerText = count;
        }
        
        if (count === 0) {
            selectedItemsContainer.innerHTML = '<div class="empty-selected">Ничего не выбрано</div>';
            return;
        }
        
        selectedItemsContainer.innerHTML = '';
        selectedItems.forEach(item => {
            const tag = document.createElement('div');
            tag.className = 'selected-tag';
            tag.innerHTML = `
                <span>${escapeHtml(item.name)}</span>
                <span class="remove-tag" data-id="${item.id}" data-type="${item.type}" data-category-id="${item.categoryId || ''}">✕</span>
            `;
            selectedItemsContainer.appendChild(tag);
        });
        
        // Добавляем обработчики на крестики
        document.querySelectorAll('.remove-tag').forEach(removeBtn => {
            removeBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                const id = removeBtn.dataset.id;
                const type = removeBtn.dataset.type;
                const categoryId = removeBtn.dataset.categoryId;
                
                if (type === 'sub') {
                    // Снимаем выделение с подкатегории
                    for (let cat of filterData) {
                        if (cat.subcategories) {
                            const sub = cat.subcategories.find(s => s.id === id);
                            if (sub) {
                                sub.selected = false;
                                break;
                            }
                        }
                    }
                } else if (type === 'category') {
                    // Снимаем выделение с категории без подкатегорий
                    const cat = filterData.find(c => c.id === id);
                    if (cat) cat.selected = false;
                }
                
                recalcAllParents();
                renderFilter();
                updateSelectedDisplay();
            });
        });
    }
    
    // Простая защита от XSS
    function escapeHtml(str) {
        return str.replace(/[&<>]/g, function(m) {
            if (m === '&') return '&amp;';
            if (m === '<') return '&lt;';
            if (m === '>') return '&gt;';
            return m;
        });
    }

    // Сброс всех фильтров
    function resetAllFilters() {
        for (let cat of filterData) {
            cat.selected = false;
            cat.indeterminate = false;
            if (cat.subcategories) {
                for (let sub of cat.subcategories) {
                    sub.selected = false;
                }
            }
        }
        recalcAllParents();
        renderFilter();
        updateSelectedDisplay();
    }

    // Рендер всего фильтра
    function renderFilter() {
        const container = document.getElementById('filterList');
        if (!container) return;

        container.innerHTML = '';
        
        for (let cat of filterData) {
            const catDiv = document.createElement('div');
            catDiv.className = 'category-item';
            if (cat.open) catDiv.classList.add('open');

            // Основная строка
            const mainRow = document.createElement('div');
            mainRow.className = 'category-main';
            if (cat.selected) mainRow.classList.add('selected');

            // левая часть с чекбоксом
            const leftDiv = document.createElement('div');
            leftDiv.className = 'category-left';

            const checkSpan = document.createElement('span');
            checkSpan.className = 'custom-check';
            
            // Отображение состояния чекбокса родителя
            if (cat.indeterminate) {
                checkSpan.classList.add('indeterminate');
            } else if (cat.selected) {
                checkSpan.classList.add('checked');
            }

            const nameSpan = document.createElement('span');
            nameSpan.className = 'category-name';
            nameSpan.innerText = cat.name;

            leftDiv.appendChild(checkSpan);
            leftDiv.appendChild(nameSpan);

            const chevronSpan = document.createElement('span');
            chevronSpan.className = 'chevron';
            chevronSpan.innerHTML = '⌵';

            // Если есть подкатегории — добавляем шеврон и логику открытия
            const hasSubcategories = cat.subcategories && cat.subcategories.length > 0;
            
            if (hasSubcategories) {
                mainRow.appendChild(leftDiv);
                mainRow.appendChild(chevronSpan);
                
                // Клик по строке (кроме чекбокса) для открытия/закрытия
                const toggleOpen = (e) => {
                    if (e.target === checkSpan || e.target === nameSpan || checkSpan.contains(e.target) || nameSpan.contains(e.target)) {
                        return;
                    }
                    cat.open = !cat.open;
                    renderFilter();
                };
                mainRow.addEventListener('click', toggleOpen);
                
                // Обработчик клика по чекбоксу/тексту — выделение всех подкатегорий
                const selectAllHandler = (e) => {
                    e.stopPropagation();
                    const newState = !cat.selected;
                    for (let sub of cat.subcategories) {
                        sub.selected = newState;
                    }
                    recalcAllParents();
                    renderFilter();
                    updateSelectedDisplay();
                };
                checkSpan.addEventListener('click', selectAllHandler);
                nameSpan.addEventListener('click', selectAllHandler);
            } else {
                // Категории без подкатегорий — клик по всей строке переключает
                mainRow.appendChild(leftDiv);
                mainRow.addEventListener('click', () => {
                    cat.selected = !cat.selected;
                    recalcAllParents();
                    renderFilter();
                    updateSelectedDisplay();
                });
            }

            catDiv.appendChild(mainRow);

            // Отрисовка подкатегорий
            if (hasSubcategories) {
                const subList = document.createElement('div');
                subList.className = 'subcategory-list';
                
                for (let sub of cat.subcategories) {
                    const subItem = document.createElement('div');
                    subItem.className = 'sub-item';
                    if (sub.selected) subItem.classList.add('selected');
                    
                    const subCheck = document.createElement('span');
                    subCheck.className = 'sub-check';
                    if (sub.selected) {
                        subCheck.classList.add('checked');
                    }
                    
                    const subLabel = document.createElement('span');
                    subLabel.className = 'sub-label';
                    subLabel.innerText = sub.name;
                    
                    subItem.appendChild(subCheck);
                    subItem.appendChild(subLabel);
                    
                    subItem.addEventListener('click', (e) => {
                        e.stopPropagation();
                        sub.selected = !sub.selected;
                        recalcAllParents();
                        renderFilter();
                        updateSelectedDisplay();
                    });
                    
                    subList.appendChild(subItem);
                }
                catDiv.appendChild(subList);
            }
            
            container.appendChild(catDiv);
        }
        
        updateSelectedDisplay();
    }

    // Инициализация — всё сброшено, изначально ничего не выбрано
    function init() {
        for (let cat of filterData) {
            cat.selected = false;
            cat.indeterminate = false;
            cat.open = false;
            if (cat.subcategories) {
                for (let sub of cat.subcategories) {
                    sub.selected = false;
                }
            }
        }
        recalcAllParents();
        renderFilter();
        
        const resetBtn = document.getElementById('resetAllBtn');
        if (resetBtn) {
            resetBtn.addEventListener('click', resetAllFilters);
        }
    }

    init();
</script>
<script>
    const reportModal = document.getElementById('reportModal');
    const reportForm = document.getElementById('reportForm');
    const reportFormFields = document.getElementById('reportFormFields');
    const reportSuccessState = document.getElementById('reportSuccessState');
    const reportReasonValue = document.getElementById('reportReasonValue');
    const reportReasonCheckboxes = document.querySelectorAll('.report-reason-checkbox');
    const complainButtons = document.querySelectorAll('.btn-complain');

    function syncReportReasonSelection(activeCheckbox) {
        if (!reportReasonCheckboxes.length) return;

        reportReasonCheckboxes.forEach((checkbox) => {
            if (checkbox !== activeCheckbox) {
                checkbox.checked = false;
            }
        });

        const selectedReason = activeCheckbox && activeCheckbox.checked ? activeCheckbox.value : '';
        if (reportReasonValue) {
            reportReasonValue.value = selectedReason;
        }
    }

    reportReasonCheckboxes.forEach((checkbox) => {
        checkbox.addEventListener('change', () => {
            syncReportReasonSelection(checkbox);
        });
    });

    function showReportModal(workId) {
        if (!reportModal) return;

        if (reportForm) {
            reportForm.action = workId ? `/works/${workId}/report` : '/works/report';
        }
        syncReportReasonSelection(null);
        if (reportFormFields) {
            reportFormFields.style.display = 'flex';
        }
        if (reportSuccessState) {
            reportSuccessState.classList.remove('is-visible');
        }

        reportModal.classList.add('is-open');
        reportModal.setAttribute('aria-hidden', 'false');
        if (typeof window.updateModalBodyState === 'function') {
            window.updateModalBodyState();
        }
    }

    function hideReportModal() {
        if (!reportModal) return;

        reportModal.classList.remove('is-open');
        reportModal.setAttribute('aria-hidden', 'true');
        if (typeof window.updateModalBodyState === 'function') {
            window.updateModalBodyState();
        }

        if (reportForm) {
            reportForm.reset();
        }
        syncReportReasonSelection(null);
        if (reportFormFields) {
            reportFormFields.style.display = 'flex';
        }
        if (reportSuccessState) {
            reportSuccessState.classList.remove('is-visible');
        }
    }

    complainButtons.forEach((button) => {
        button.addEventListener('click', () => {
            showReportModal(button.dataset.workId || '');
        });
    });



    window.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && reportModal && reportModal.classList.contains('is-open')) {
            hideReportModal();
        }
    });

    if (reportForm) {
        reportForm.addEventListener('submit', (event) => {
            event.preventDefault();

            if (!reportForm.checkValidity()) {
                reportForm.reportValidity();
                return;
            }

            if (reportFormFields) {
                reportFormFields.style.display = 'none';
            }
            if (reportSuccessState) {
                reportSuccessState.classList.add('is-visible');
            }

            reportForm.reset();
        });
    }
</script>
