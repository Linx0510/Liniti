<script>
(function() {
        // полный текст с описанием проекта
        const fullText = `Daaiih BbINONHeH B BepTMKanbHoM формате c четким разделением на две смысловые части, где центральным элементом выступает крупное превью, демонстрирующее продукт. Цветовая гамма построена на контрасте плотного белого фона с яркими градиентными элементами (оранжевый, шафрановый, терракотовый) и неоново-салатовыми акцентами, которые подчеркивают динамику и современный стиль интерфейса.`;
        
        // лимит символов для отображения
        const CHAR_LIMIT = 300;
        
        // Находим все блоки .post-text-content
        const allPostBlocks = document.querySelectorAll('.post-text-content');
        
        allPostBlocks.forEach((postBlock, index) => {
            // Находим внутри каждого блока нужные элементы
            const textContainer = postBlock.querySelector('#textContainer');
            const bottomContainer = postBlock.querySelector('#bottomButtonContainer');
            
            if (!textContainer || !bottomContainer) return;
            
            let isExpanded = false;
            let animationInProgress = false;
            
            // функция для получения полной высоты блока
            function getFullHeight() {
                const currentHeight = postBlock.style.height;
                postBlock.style.height = 'auto';
                const fullHeight = postBlock.offsetHeight;
                postBlock.style.height = currentHeight;
                return fullHeight;
            }
            
            // функция для плавного изменения высоты
            function animateHeight(targetHeight, callback) {
                const startHeight = postBlock.offsetHeight;
                
                if (Math.abs(startHeight - targetHeight) < 1) {
                    postBlock.style.height = '';
                    if (callback) callback();
                    return;
                }
                
                const startTime = performance.now();
                const duration = 300;
                
                function update(currentTime) {
                    const elapsed = currentTime - startTime;
                    const progress = Math.min(elapsed / duration, 1);
                    const easeProgress = 1 - Math.pow(1 - progress, 3);
                    
                    const newHeight = startHeight + (targetHeight - startHeight) * easeProgress;
                    postBlock.style.height = newHeight + 'px';
                    
                    if (progress < 1) {
                        requestAnimationFrame(update);
                    } else {
                        postBlock.style.height = '';
                        if (callback) callback();
                    }
                }
                
                requestAnimationFrame(update);
            }
            
            function init() {
                textContainer.innerHTML = '';
                bottomContainer.innerHTML = '';
                bottomContainer.classList.add('hidden');
                
                // если текст короче лимита — показываем полностью без кнопок
                if (fullText.length <= CHAR_LIMIT) {
                    const textSpan = document.createElement('span');
                    textSpan.textContent = fullText;
                    textContainer.appendChild(textSpan);
                    return;
                }
                
                const visiblePart = fullText.slice(0, CHAR_LIMIT);
                const remainder = fullText.slice(CHAR_LIMIT);
                
                // создаем элементы
                const visibleSpan = document.createElement('span');
                visibleSpan.className = 'visible-text';
                visibleSpan.textContent = visiblePart;
                
                const dotsSpan = document.createElement('span');
                dotsSpan.className = 'dots';
                dotsSpan.textContent = '... ';
                
                const hiddenWrapper = document.createElement('span');
                hiddenWrapper.className = 'hidden-wrapper';
                
                const hiddenSpan = document.createElement('span');
                hiddenSpan.className = 'hidden-text';
                hiddenSpan.textContent = remainder;
                
                hiddenWrapper.appendChild(hiddenSpan);
                
                const inlineBtn = document.createElement('button');
                inlineBtn.className = 'inline-toggle-btn';
                inlineBtn.textContent = 'Показать еще';
                
                textContainer.appendChild(visibleSpan);
                textContainer.appendChild(dotsSpan);
                textContainer.appendChild(inlineBtn);
                textContainer.appendChild(hiddenWrapper);
                
                // обработчик для кнопки "показать еще"
                inlineBtn.addEventListener('click', function() {
                    if (isExpanded || animationInProgress) return;
                    
                    const startHeight = postBlock.offsetHeight;
                    postBlock.style.height = startHeight + 'px';
                    
                    expandText(dotsSpan, inlineBtn, hiddenSpan);
                });
            }
            
            function expandText(dotsSpan, inlineBtn, hiddenSpan) {
                animationInProgress = true;
                isExpanded = true;
                
                // скрываем троеточие и кнопку в строке
                dotsSpan.style.display = 'none';
                inlineBtn.style.display = 'none';
                
                // показываем скрытый текст
                hiddenSpan.classList.add('show');
                
                // создаем кнопку "скрыть текст" снизу
                createBottomButton(dotsSpan, inlineBtn, hiddenSpan);
                
                // ждем рендеринга и плавно меняем высоту
                setTimeout(() => {
                    const targetHeight = getFullHeight();
                    animateHeight(targetHeight, () => {
                        animationInProgress = false;
                    });
                }, 10);
            }
            
            function createBottomButton(dotsSpan, inlineBtn, hiddenSpan) {
                bottomContainer.innerHTML = '';
                bottomContainer.classList.remove('hidden');
                
                const bottomBtn = document.createElement('button');
                bottomBtn.className = 'bottom-toggle-btn';
                bottomBtn.textContent = 'Скрыть текст';
                
                bottomContainer.appendChild(bottomBtn);
                
                bottomBtn.addEventListener('click', function() {
                    if (!isExpanded || animationInProgress) return;
                    
                    const startHeight = postBlock.offsetHeight;
                    postBlock.style.height = startHeight + 'px';
                    
                    collapseText(dotsSpan, inlineBtn, hiddenSpan);
                });
            }
            
            function collapseText(dotsSpan, inlineBtn, hiddenSpan) {
                animationInProgress = true;
                
                // скрываем нижнюю кнопку
                bottomContainer.classList.add('hidden');
                bottomContainer.innerHTML = '';
                
                // скрываем скрытый текст
                hiddenSpan.classList.remove('show');
                
                // показываем троеточие и кнопку в строке
                dotsSpan.style.display = 'inline';
                inlineBtn.style.display = 'inline-flex';
                
                // вычисляем новую высоту и плавно меняем
                setTimeout(() => {
                    const targetHeight = getFullHeight();
                    animateHeight(targetHeight, () => {
                        animationInProgress = false;
                    });
                }, 10);
                
                isExpanded = false;
            }
            
            init();
        });
    })();
</script>
<script>
(function () {
    const lenta = document.querySelector('.lenta');
    const imageViewerModal = document.getElementById('imageViewerModal');
    const viewerTrack = document.getElementById('viewerTrack');
    const viewerDots = document.getElementById('viewerDots');
    const viewerPrev = document.getElementById('viewerPrev');
    const viewerNext = document.getElementById('viewerNext');

    if (!lenta) return;
    let viewerImages = [];
    let viewerCurrentIndex = 0;

    window.updateModalBodyState = function updateModalBodyState() {
        const hasOpenModal = Boolean(document.querySelector('.report-modal.is-open, .image-viewer-modal.is-open'));
        document.body.classList.toggle('modal-open', hasOpenModal);
    };

    function canScroll(el, deltaY) {
        if (!el) return false;
        if (deltaY > 0) {
            return el.scrollTop + el.clientHeight < el.scrollHeight;
        }
        return el.scrollTop > 0;
    }

    document.addEventListener('wheel', (event) => {
        const openModal = document.querySelector('.report-modal.is-open, .image-viewer-modal.is-open');
        if (openModal) {
            const modalScrollable = event.target.closest('.report-modal-content, .image-viewer-content');
            if (modalScrollable && canScroll(modalScrollable, event.deltaY)) {
                return;
            }
            return;
        }

        const scrollableParent = event.target.closest('.dropdown-notific, .filter-list, .selected-items-list, .lenta');

        if (scrollableParent && scrollableParent !== lenta && canScroll(scrollableParent, event.deltaY)) {
            return;
        }

        lenta.scrollBy({ top: event.deltaY, behavior: 'auto' });
        event.preventDefault();
    }, { passive: false });

    function updateImageViewer() {
        if (!viewerTrack || !viewerDots) return;

        viewerTrack.style.transform = `translateX(-${viewerCurrentIndex * 100}%)`;
        Array.from(viewerDots.children).forEach((dot, index) => {
            dot.classList.toggle('active', index === viewerCurrentIndex);
        });
    }

    window.showImageViewer = function showImageViewer(images, startIndex = 0) {
        if (!imageViewerModal || !viewerTrack || !viewerDots) return;

        viewerImages = images;
        viewerCurrentIndex = startIndex;
        viewerTrack.innerHTML = '';
        viewerDots.innerHTML = '';

        viewerImages.forEach((image, index) => {
            const slide = document.createElement('div');
            slide.className = 'image-viewer-slide';

            const img = document.createElement('img');
            img.src = image.src;
            img.alt = image.alt || `Изображение ${index + 1}`;
            slide.appendChild(img);
            viewerTrack.appendChild(slide);

            const dot = document.createElement('button');
            dot.type = 'button';
            dot.className = 'dot';
            dot.setAttribute('aria-label', `Перейти к изображению ${index + 1}`);
            dot.addEventListener('click', () => {
                viewerCurrentIndex = index;
                updateImageViewer();
            });
            viewerDots.appendChild(dot);
        });

        imageViewerModal.classList.add('is-open');
        imageViewerModal.setAttribute('aria-hidden', 'false');
        window.updateModalBodyState();
        updateImageViewer();
    };

    window.hideImageViewer = function hideImageViewer() {
        if (!imageViewerModal || imageViewerModal.getAttribute('aria-hidden') === 'true') return;

        imageViewerModal.classList.remove('is-open');
        imageViewerModal.setAttribute('aria-hidden', 'true');
        window.updateModalBodyState();
    };

    if (viewerPrev) {
        viewerPrev.addEventListener('click', () => {
            if (!viewerImages.length) return;
            viewerCurrentIndex = (viewerCurrentIndex - 1 + viewerImages.length) % viewerImages.length;
            updateImageViewer();
        });
    }

    if (viewerNext) {
        viewerNext.addEventListener('click', () => {
            if (!viewerImages.length) return;
            viewerCurrentIndex = (viewerCurrentIndex + 1) % viewerImages.length;
            updateImageViewer();
        });
    }

    window.addEventListener('keydown', (event) => {
        const viewerOpened = imageViewerModal && imageViewerModal.classList.contains('is-open');
        if (!viewerOpened) return;

        if (event.key === 'Escape') {
            window.hideImageViewer();
        } else if (event.key === 'ArrowLeft' && viewerImages.length) {
            viewerCurrentIndex = (viewerCurrentIndex - 1 + viewerImages.length) % viewerImages.length;
            updateImageViewer();
        } else if (event.key === 'ArrowRight' && viewerImages.length) {
            viewerCurrentIndex = (viewerCurrentIndex + 1) % viewerImages.length;
            updateImageViewer();
        }
    });

    document.querySelectorAll('[data-gallery]').forEach((gallery) => {
        const track = gallery.querySelector('[data-gallery-track]');
        const slides = Array.from(track.children);
        const prevBtn = gallery.querySelector('[data-gallery-prev]');
        const nextBtn = gallery.querySelector('[data-gallery-next]');

        let currentIndex = 0;

        const dotsContainer = document.createElement('div');
        dotsContainer.className = 'gallery-dots';

        const dots = slides.map((_, index) => {
            const dot = document.createElement('button');
            dot.type = 'button';
            dot.className = 'dot';
            dot.setAttribute('aria-label', `Перейти к изображению ${index + 1}`);
            dot.addEventListener('click', () => {
                currentIndex = index;
                updateGallery();
            });
            dotsContainer.appendChild(dot);
            return dot;
        });

        gallery.appendChild(dotsContainer);

        function updateGallery() {
            track.style.transform = `translateX(-${currentIndex * 100}%)`;
            dots.forEach((dot, index) => {
                dot.classList.toggle('active', index === currentIndex);
            });
        }

        prevBtn.addEventListener('click', () => {
            currentIndex = (currentIndex - 1 + slides.length) % slides.length;
            updateGallery();
        });

        nextBtn.addEventListener('click', () => {
            currentIndex = (currentIndex + 1) % slides.length;
            updateGallery();
        });

        slides.forEach((slide, index) => {
            const image = slide.querySelector('img');
            if (!image) return;

            image.addEventListener('click', () => {
                const images = slides
                    .map((gallerySlide) => gallerySlide.querySelector('img'))
                    .filter(Boolean)
                    .map((img) => ({ src: img.src, alt: img.alt }));
                window.showImageViewer(images, index);
            });
        });

        updateGallery();
    });
})();
</script>

