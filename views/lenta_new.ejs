        const originalPositions = [
            { x: 76.6035, y: 13.1301 },
            { x: 105.049, y: 13.1301 },
            { x: 76.6001, y: 50.3345 },
            { x: 105.057, y: 50.3345 }
        ];
        const rotatedPositions = [
            { x: 105.049, y: 13.1301 },
            { x: 105.057, y: 50.3345 },
            { x: 76.6035, y: 13.1301 },
            { x: 76.6001, y: 50.3345 }
        ];
        function animateRectsToRotated() {
            if (svgRects.length === 4) {
                svgRects.forEach((rect, idx) => {
                    rect.setAttribute('x', rotatedPositions[idx].x);
                    rect.setAttribute('y', rotatedPositions[idx].y);
                });
            }
        }
        function animateRectsToOriginal() {
            if (svgRects.length === 4) {
                svgRects.forEach((rect, idx) => {
                    rect.setAttribute('x', originalPositions[idx].x);
                    rect.setAttribute('y', originalPositions[idx].y);
                });
            }
        }
        if (logoLinkElem) {
            logoLinkElem.addEventListener('mouseenter', animateRectsToRotated);
            logoLinkElem.addEventListener('mouseleave', animateRectsToOriginal);
